{"variants":[{"paths":["\/documentation\/recordscalendarui"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"url":"doc:\/\/recordscalendarui.RecordsCalendarUI\/documentation\/RecordsCalendarUI","interfaceLanguage":"swift"},"sections":[],"hierarchy":{"paths":[[]]},"primaryContentSections":[{"content":[{"anchor":"Overview","type":"heading","text":"Overview","level":2},{"inlineContent":[{"type":"codeVoice","code":"RecordsCalendarUI"},{"type":"text","text":" provides presentation-only calendar components for record-based apps. Host apps pass records, display configuration, selection state, and callbacks while keeping storage and detail navigation outside the package."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Use this package when you need a reusable week\/month calendar with a selected-day list and swipe-to-delete behavior, but each app needs different record values, text formatting, and detail screens."}],"type":"paragraph"},{"inlineContent":[{"code":"RecordsCalendarConfiguration.rowHeight","type":"codeVoice"},{"type":"text","text":" controls the minimum selected-day list slot height for each row. "},{"code":"RecordsCalendarConfiguration.rowSpacing","type":"codeVoice"},{"type":"text","text":" controls the vertical spacing between selected-day rows, defaults to 5 points, can be customized by host apps, and clamps negative values to zero. Values below "},{"code":"RecordsCalendarConfiguration<YourRecord>.minimumRowHeight","type":"codeVoice"},{"type":"text","text":", currently 49 points with the default spacing, are clamped so row content keeps a standard touch target while preserving compact spacing between selected-day rows. For custom spacing, use "},{"code":"RecordsCalendarConfiguration<YourRecord>.minimumRowHeight(forRowSpacing:)","type":"codeVoice"},{"type":"text","text":" to calculate the matching protected minimum."}],"type":"paragraph"}],"kind":"content"}],"kind":"symbol","topicSections":[{"identifiers":["doc:\/\/recordscalendarui.R