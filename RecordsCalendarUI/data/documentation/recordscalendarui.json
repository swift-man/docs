"type":"topic","title":"RecordsCalendarConfiguration","abstract":[],"identifier":"doc:\/\/recordscalendarui.RecordsCalendarUI\/documentation\/RecordsCalendarUI\/RecordsCalendarConfiguration","navigatorTitle":[{"kind":"identifier","text":"RecordsCalendarConfiguration"}],"role":"symbol"},"doc://recordscalendarui.RecordsCalendarUI/documentation/RecordsCalendarUI/RecordsCalendarDisplayScope":{"abstract":[],"type":"topic","kind":"symbol","identifier":"doc:\/\/recordscalendarui.RecordsCalendarUI\/documentation\/RecordsCalendarUI\/RecordsCalendarDisplayScope","title":"RecordsCalendarDisplayScope","role":"symbol","url":"\/documentation\/recordscalendarui\/recordscalendardisplayscope","navigatorTitle":[{"text":"RecordsCalendarDisplayScope","kind":"identifier"}],"fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"RecordsCalendarDisplayScope","kind":"identifier"}]},"doc://recordscalendarui.RecordsCalendarUI/documentation/RecordsCalendarUI/RecordsCalendarView":{"role":"symbol","navigatorTitle":[{"text":"RecordsCalendarView","kind":"identifier"}],"title":"RecordsCalendarView","kind":"symbol","abstract":[],"identifier":"doc:\/\/recordscalendarui.RecordsCalendarUI\/documentation\/RecordsCalendarUI\/RecordsCalendarView","url":"\/documentation\/recordscalendarui\/recordscalendarview","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"RecordsCalendarView","kind":"identifier"}],"type":"topic"}}}