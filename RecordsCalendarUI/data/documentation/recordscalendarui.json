ordsCalendarUI\/RecordsCalendarTheme","abstract":[],"role":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"RecordsCalendarTheme"}]},"doc://recordscalendarui.RecordsCalendarUI/documentation/RecordsCalendarUI/RecordsCalendarConfiguration":{"navigatorTitle":[{"kind":"identifier","text":"RecordsCalendarConfiguration"}],"role":"symbol","type":"topic","kind":"symbol","identifier":"doc:\/\/recordscalendarui.RecordsCalendarUI\/documentation\/RecordsCalendarUI\/RecordsCalendarConfiguration","abstract":[],"title":"RecordsCalendarConfiguration","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"RecordsCalendarConfiguration"}],"url":"\/documentation\/recordscalendarui\/recordscalendarconfiguration"}}}