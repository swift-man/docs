{"identifier":{"url":"doc:\/\/recordscalendarui.RecordsCalendarUI\/documentation\/RecordsCalendarUI","interfaceLanguage":"swift"},"abstract":[{"type":"text","text":"Reusable SwiftUI calendar records UI for apps that own their own data, persistence, and navigation."}],"variants":[{"paths":["\/documentation\/recordscalendarui"],"traits":[{"interfaceLanguage":"swift"}]}],"metadata":{"title":"RecordsCalendarUI","role":"collection","roleHeading":"Framework","modules":[{"name":"RecordsCalendarUI"}],"externalID":"RecordsCalendarUI","symbolKind":"module"},"sections":[],"primaryContentSections":[{"kind":"content","content":[{"type":"heading","level":2,"anchor":"Overview","text":"Overview"},{"type":"paragraph","inlineContent":[{"code":"RecordsCalendarUI","type":"codeVoice"},{"text":" provides presentation-only calendar components for record-based apps. Host apps pass records, display configuration, selection state, and callbacks while keeping storage and detail navigation outside the package.","type":"text"}]},{"inlineContent":[{"text":"Use this package when you need a reusable week\/month calendar with a selected-day list and swipe-to-delete behavior, but each app needs different record values, text formatting, and detail screens.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"code":"RecordsCalendarConfiguration.rowHeight","type":"codeVoice"},{"type":"text","text":" controls the minimum selected-day row card height. "},{"type":"codeVoice","code":"RecordsCalendarConfiguration.rowSpacing"},{"type":"text","text":" controls the vertical spacing between selected-day rows, defaults to 5 points, can be customized by host apps, and clamps negative values to zero. Values below "},{"type":"codeVoice","code":"RecordsCalendarConfiguration<YourRecord>.minimumRowHeight"},{"type":"text","text":", currently 44 points, are clamped so row content keeps a standard touch target. Row spacing does not reduce the configured row height. "},{"type":"codeVoice","code":"RecordsCalendarConfiguration<YourRecord>.minimumRowHeight(forRowSpacing:)"},{"type":"text","text":" remains as a deprecated compatibility helper; use "},{"type":"codeVoice","code":"minimumRowHeight"},{"type":"text","text":" for new code."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Calendar day buttons can receive an accessibility label and value from "},{"type":"codeVoice","code":"RecordsCalendarConfiguration"},{"type":"text","text":". The package passes a "},{"type":"codeVoice","code":"RecordsCalendarDayAccessibilityContext"},{"type":"text","text":" with the date, its display calendar, and the today, selected, and has-records states so host apps can provide their own localized full-date label and state text. Use "},{"type":"codeVoice","code":"context.calendar"},{"type":"text","text":" when formatting the date so its locale and time zone stay consistent with the visible calendar. When these closures are omitted, the package preserves SwiftUI’s default day-number announcement. Selected dates also use the system selected accessibility trait."}],"type":"paragraph"}]}],"kind":"symbol","topicSections":[{"title":"Calendar Presentation","anchor":"Calendar-Presentation","identifiers":["doc:\/\/recordscalendarui.RecordsCalendarUI\/documentation\/RecordsCalendarUI\/RecordsCalendarView","doc:\/\/recordscalendarui.RecordsCalendarUI\/documentation\/RecordsCalendarUI\/RecordsCalendarConfiguration","doc:\/\/recordscalendarui.RecordsCalendarUI\/documentation\/RecordsCalendarUI\/RecordsCalendarDisplayScope"]},{"title":"Record Model Boundary","identifiers":["doc:\/\/recordscalendarui.RecordsCalendarUI\/documentation\/RecordsCalendarUI\/RecordsCalendarEntry"],"anchor":"Record-Model-Boundary"},{"title":"Structures","generated":true,"anchor":"Structures","identifiers":["doc:\/\/recordscalendarui.RecordsCalendarUI\/documentation\/RecordsCalendarUI\/RecordsCalendarBestValueComparator","doc:\/\/recordscalendarui.RecordsCalendarUI\/documentation\/RecordsCalendarUI\/RecordsCalendarDayAccessibilityContext"]}],"hierarchy":{"paths":[[]]},"schemaVersion":{"minor":3,"patch":0,"major":0},"references":{"doc://recordscalendarui.RecordsCalendarUI/documentation/RecordsCalendarUI":{"url":"\/documentation\/recordscalendarui","type":"topic","role":"collection","abstract":[{"text":"Reusable SwiftUI calendar records UI for apps that own their own data, persistence, and navigation.","type":"text"}],"identifier":"doc:\/\/recordscalendarui.RecordsCalendarUI\/documentation\/RecordsCalendarUI","kind":"symbol","title":"RecordsCalendarUI"},"doc://recordscalendarui.RecordsCalendarUI/documentation/RecordsCalendarUI/RecordsCalendarDayAccessibilityContext":{"role":"symbol","title":"RecordsCalendarDayAccessibilityContext","navigatorTitle":[{"kind":"identifier","text":"RecordsCalendarDayAccessibilityContext"}],"url":"\/documentation\/recordscalendarui\/recordscalendardayaccessibilitycontext","kind":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"RecordsCalendarDayAccessibilityContext"}],"abstract":[],"identifier":"doc:\/\/recordscalendarui.RecordsCalendarUI\/documentation\/RecordsCalendarUI\/RecordsCalendarDayAccessibilityContext","type":"topic"},"doc://recordscalendarui.RecordsCalendarUI/documentation/RecordsCalendarUI/RecordsCalendarEntry":{"kind":"symbol","role":"symbol","abstract":[],"title":"RecordsCalendarEntry","fragments":[{"kind":"keyword","text":"protocol"},{"text":" ","kind":"text"},{"text":"RecordsCalendarEntry","kind":"identifier"}],"identifier":"doc:\/\/recordscalendarui.RecordsCalendarUI\/documentation\/RecordsCalendarUI\/RecordsCalendarEntry","type":"topic","navigatorTitle":[{"kind":"identifier","text":"RecordsCalendarEntry"}],"url":"\/documentation\/recordscalendarui\/recordscalendarentry"},"doc://recordscalendarui.RecordsCalendarUI/documentation/RecordsCalendarUI/RecordsCalendarConfiguration":{"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"RecordsCalendarConfigur