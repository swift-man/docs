{"primaryContentSections":[{"content":[{"text":"Overview","type":"heading","level":2,"anchor":"Overview"},{"inlineContent":[{"type":"codeVoice","code":"RecordsCalendarUI"},{"type":"text","text":" provides presentation-only calendar components for record-based apps. Host apps pass records, display configuration, selection state, and callbacks while keeping storage and detail navigation outside the package."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Use this package when you need a reusable week\/month calendar with a selected-day list and swipe-to-delete behavior, but each app needs different record values, text formatting, and detail screens."}],"type":"paragraph"},{"inlineContent":[{"type":"codeVoice","code":"RecordsCalendarConfiguration.rowHeight"},{"type":"text","text":" controls the minimum selected-day list slot height for each row. Values below "},{"type":"codeVoice","code":"RecordsCalendarConfiguration<YourRecord>.minimumRowHeight"},{"type":"text","text":", currently 82 points, are clamped so row content keeps its vertical inset, padding, and touch target."}],"type":"paragraph"}],"kind":"content"}],"hierarchy":{"paths":[[]]},"kind":"symbol","sections":[],"topicSections":[{"identifiers":["doc:\/\/recordscalendarui.RecordsCalendarUI\/documentation\/RecordsCalendarUI\/RecordsCalendarView","doc:\/\/recordscalendarui.RecordsCalendarUI\/documentation\/RecordsCalendarUI\/RecordsCalendarConfiguration","doc:\/\/recordscalendarui.RecordsCalendarUI\/documentation\/RecordsCalendarUI\/RecordsCalendarDisplayScope"],"anchor":"Calendar-Presentation","title":"Calendar Presentation"},{"identifiers":["doc:\/\/recordscalendarui.RecordsCalendarUI\/documentation\/RecordsCalendarUI\/RecordsCalendarEntry"],"anchor":"Record-Model-Boundary","title":"Record Model Boundary"},{"generated":true,"identifiers":["doc:\/\/recordscalendarui.RecordsCalendarUI\/documentation\/RecordsCalendarUI\/RecordsCalendarBestValueComparator"],"anchor":"Structures","title":"Structures"}]