{"sections":[],"topicSections":[{"title":"Calendar Presentation","anchor":"Calendar-Presentation","identifiers":["doc:\/\/recordscalendarui.RecordsCalendarUI\/documentation\/RecordsCalendarUI\/RecordsCalendarView","doc:\/\/recordscalendarui.RecordsCalendarUI\/documentation\/RecordsCalendarUI\/RecordsCalendarConfiguration","doc:\/\/recordscalendarui.RecordsCalendarUI\/documentation\/RecordsCalendarUI\/RecordsCalendarTheme","doc:\/\/recordscalendarui.RecordsCalendarUI\/documentation\/RecordsCalendarUI\/RecordsCalendarDisplayScope"]},{"title":"Record Model Boundary","anchor":"Record-Model-Boundary","identifiers":["doc:\/\/recordscalendarui.RecordsCalendarUI\/documentation\/RecordsCalendarUI\/RecordsCalendarEntry"]},{"generated":true,"title":"Structures","anchor":"Structures","identifiers":["doc:\/\/recordscalendarui.RecordsCalendarUI\/documentation\/RecordsCalendarUI\/RecordsCalendarBestValueComparator","doc:\/\/recordscalendarui.RecordsCalendarUI\/documentation\/RecordsCalendarUI\/RecordsCalendarDayAccessibilityContext"]}],"hierarchy":{"paths":[[]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/recordscalendarui"]}],"schemaVersion":{"patch":0,"minor":3,"major":0},"identifier":{"url":"doc:\/\/recordscalendarui.RecordsCalendarUI\/documentation\/RecordsCalendarUI","interfaceLanguage":"swift"},"metadata":{"roleHeading":"Framework","symbolKind":"module","modules":[{"name":"RecordsCalendarUI"}],"role":"collection","title":"RecordsCalendarUI","externalID":"RecordsCalendarUI"},"abstract":[{"type":"text","text":"Reusable SwiftUI calendar records UI for apps that own their own data, persistence, and navigation."}],"kind":"symbol","primaryContentSections":[{"kind":"content","content":[{"level":2,"anchor":"Overview","type":"heading","text":"Overview"},{"inlineContent":[{"code":"RecordsCalendarUI","type":"codeVoice"},{"text":" provides presentation-only calendar components for record-based apps. Host apps pass records, display configuration, selection state, and callbacks while keeping storage and detail navigation outside the package.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Use this package when you need a reusable week\/month calendar with a selected-day list and swipe-to-delete behavior, but each app needs different record values, text formatting, and detail screens."}],"type":"paragraph"},{"inlineContent":[{"type":"codeVoice","code":"RecordsCalendarConfiguration.rowHeight"},{"type":"text","text":" controls the minimum selected-day row card height. "},{"type":"codeVoice","code":"RecordsCalendarConfiguration.rowSpacing"},{"type":"text","text":" controls the vertical spacing between selected-day rows, defaults to 5 points, can be customized by host apps, and clamps negative values to zero. Values below "},{"type":"codeVoice","code":"RecordsCalendarConfiguration<YourRecord>.minimumRowHeight"},{"type":"text","text":", currently 44 points, are clamped so row content keeps a standard touch target. Row spacing does not reduce the configured row height. "},{"type":"codeVoice","code":"RecordsCalendarConfiguration<YourRecord>.minimumRowHeight(forRowSpacing:)"},{"type":"text","text":" remains as a deprecated compatibility helper; use "},{"type":"codeVoice","code":"minimumRowHeight"},{"type":"text","text":" for new code."}],"type":"paragraph"},{"inlineContent":[{"type":"codeVoice","code":"RecordsCalendarConfiguration.theme"},{"type":"text","text":" accepts semantic colors through "},{"type":"codeVoice","code":"RecordsCalendarTheme"},{"type":"text","text":", including the full-page background, calendar and record container background, primary and secondary content colors, and independent light and dark summary tile backgrounds. The default "},{"code":".standard","type":"codeVoice"},{"type":"text","text":" theme preserves the system grouped page background, material calendar container, grouped record containers, and existing green appearance. Host apps can supply adaptive SwiftUI colors without changing package internals."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Theme initialization without an explicit light-mode secondary content color remains supported and derives that color from "},{"type":"codeVoice","code":"contentColor"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"To change only surfaces, copy "},{"type":"codeVoice","code":".standard"},{"type":"text","text":" and set "},{"type":"codeVoice","code":"backgroundColor"},{"type":"text","text":" or "},{"type":"codeVoice","code":"containerBackgroundColor"},{"type":"text","text":". The package applies the container color consistently to the calendar, selected-day empty state, and record rows."}]},{"type":"paragraph","inlineContent":[{"text":"Calendar day buttons can receive an accessibility label and value from ","type":"text"},{"code":"RecordsCalendarConfiguration","type":"codeVoice"},{"text":". The package passes a ","type":"text"},{"code":"RecordsCalendarDayAccessibilityContext","type":"codeVoice"},{"text":" with the date, its display calendar, and the today, selected, and has-records states so host apps can provide their own localized full-date label and state text. Use ","type":"text"},{"code":"context.calendar","type":"codeVoice"},{"text":" when formatting the date so its locale and time zone stay consistent with the visible calendar. When these closures are omitted, the package preserves SwiftUI’s default day-number announcement. Selected dates also use the system selected accessibility trait.","type":"text"}]}]}],"references":{"doc://recordscalendarui.RecordsCalendarUI/documentation/RecordsCalendarUI/RecordsCalendarBestValueComparator":{"kind":"symbol","type":"topic","title":"RecordsCalendarBestValueComparator","navigatorTitle":[{"kind":"identifier","text":"RecordsCalendarBestValueComparator"}],"identifier":"doc:\/\/recordscalendarui.RecordsCalendarUI\/documentation\/RecordsCalendarUI\/RecordsCalendar