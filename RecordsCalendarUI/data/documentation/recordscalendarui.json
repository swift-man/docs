Context","kind":"identifier"}],"url":"\/documentation\/recordscalendarui\/recordscalendardayaccessibilitycontext","title":"RecordsCalendarDayAccessibilityContext"},"doc://recordscalendarui.RecordsCalendarUI/documentation/RecordsCalendarUI":{"title":"RecordsCalendarUI","type":"topic","abstract":[{"type":"text","text":"Reusable SwiftUI calendar records UI for apps that own their own data, persistence, and navigation."}],"url":"\/documentation\/recordscalendarui","role":"collection","identifier":"doc:\/\/recordscalendarui.RecordsCalendarUI\/documentation\/RecordsCalendarUI","kind":"symbol"},"doc://recordscalendarui.RecordsCalendarUI/documentation/RecordsCalendarUI/RecordsCalendarTheme":{"type":"topic","navigatorTitle":[{"text":"RecordsCalendarTheme","kind":"identifier"}],"abstract":[],"identifier":"doc:\/\/recordscalendarui.RecordsCalendarUI\/documentation\/RecordsCalendarUI\/RecordsCalendarTheme","kind":"symbol","role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"RecordsCalendarTheme","kind":"identifier"}],"url":"\/documentation\/recordscalendarui\/recordscalendartheme","title":"RecordsCalendarTheme"},"doc://recordscalendarui.RecordsCalendarUI/documentation/RecordsCalendarUI/RecordsCalendarEntry":{"fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"RecordsCalendarEntry","kind":"identifier"}],"identifier":"doc:\/\/recordscalendarui.RecordsCalendarUI\/documentation\/RecordsCalendarUI\/RecordsCalendarEntry","kind":"symbol","type":"topic","url":"\/documentation\/recordscalendarui\/recordscalendarentry","role":"symbol","navigatorTitle":[{"text":"RecordsCalendarEntry","kind":"identifier"}],"title":"RecordsCalendarEntry","abstract":[]}}}