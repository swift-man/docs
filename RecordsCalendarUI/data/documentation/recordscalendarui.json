{"hierarchy":{"paths":[[]]},"schemaVersion":{"major":0,"patch":0,"minor":3},"topicSections":[{"identifiers":["doc:\/\/recordscalendarui.RecordsCalendarUI\/documentation\/RecordsCalendarUI\/RecordsCalendarView","doc:\/\/recordscalendarui.RecordsCalendarUI\/documentation\/RecordsCalendarUI\/RecordsCalendarConfiguration","doc:\/\/recordscalendarui.RecordsCalendarUI\/documentation\/RecordsCalendarUI\/RecordsCalendarTheme","doc:\/\/recordscalendarui.RecordsCalendarUI\/documentation\/RecordsCalendarUI\/RecordsCalendarDisplayScope"],"anchor":"Calendar-Presentation","title":"Calendar Presentation"},{"identifiers":["doc:\/\/recordscalendarui.RecordsCalendarUI\/documentation\/RecordsCalendarUI\/RecordsCalendarEntry"],"anchor":"Record-Model-Boundary","title":"Record Model Boundary"},{"generated":true,"identifiers":["doc:\/\/recordscalendarui.RecordsCalendarUI\/documentation\/RecordsCalendarUI\/RecordsCalendarBestValueComparator","doc:\/\/recordscalendarui.RecordsCalendarUI\/documentation\/RecordsCalendarUI\/RecordsCalendarDayAccessibilityContext"],"anchor":"Structures","title":"Structures"}],"kind":"symbol","metadata":{"role":"collection","modules":[{"name":"RecordsCalendarUI"}],"title":"RecordsCalendarUI","roleHeading":"Framework","externalID":"RecordsCalendarUI","symbolKind":"module"},"identifier":{"url":"doc:\/\/recordscalendarui.RecordsCalendarUI\/documentation\/RecordsCalendarUI","interfaceLanguage":"swift"},"sections":[],"abstract":[{"type":"text","text":"Reusable SwiftUI calendar records UI for apps that own their own data, persistence, and navigation."}],"primaryContentSections":[{"content":[{"anchor":"Overview","text":"Overview","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"code":"RecordsCalendarUI","type":"codeVoice"},{"text":" provides presentation-only calendar components for record-based apps. Host apps pass records, display configuration, selection state, and callbacks while keeping storage and detail navigation outside the package.","type":"text"}]},{"inlineContent":[{"text":"Use this package when you need a reusable week\/month calendar with a selected-day list and swipe-to-delete behavior, but each app needs different record values, text formatting, and detail screens.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"code":"RecordsCalendarConfiguration.rowHeight","type":"codeVoice"},{"text":" controls the minimum selected-day row card height. ","type":"text"},{"code":"RecordsCalendarConfiguration.rowSpacing","type":"codeVoice"},{"text":" controls the vertical spacing between selected-day rows, defaults to 5 points, can be customized by host apps, and clamps negative values to zero. Values below ","type":"text"},{"code":"RecordsCalendarConfiguration<YourRecord>.minimumRowHeight","type":"codeVoice"},{"text":", currently 44 points, are clamped so row content keeps a standard touch target. Row spacing does not reduce the configured row height. ","type":"text"},{"code":"RecordsCalendarConfiguration<YourRecord>.minimumRowHeight(forRowSpacing:)","type":"codeVoice"},{"text":" remains as a deprecated compatibility helper; use ","type":"text"},{"code":"minimumRowHeight","type":"codeVoice"},{"text":" for new code.","type":"text"}]},{"inlineContent":[{"type":"codeVoice","code":"RecordsCalendarConfiguration.theme"},{"text":" accepts semantic summary and calendar colors through ","type":"text"},{"type":"codeVoice","code":"RecordsCalendarTheme"},{"text":", including primary and secondary summary content colors and independent light and dark summary tile backgrounds. The default ","type":"text"},{"type":"codeVoice","code":".standard"},{"text":" theme preserves the existing green appearance while host apps can supply brand colors without changing package internals.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Theme initialization without an explicit light-mode secondary content color remains supported and derives that color from "},{"code":"contentColor","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"Calendar day buttons can receive an accessibility label and value from ","type":"text"},{"code":"RecordsCalendarConfiguration","type":"codeVoice"},{"text":". The package passes a ","type":"text"},{"code":"RecordsCalendarDayAccessibilityContext","type":"codeVoice"},{"text":" with the date, its display calendar, and the today, selected, and has-records states so host apps can provide their own localized full-date label and state text. Use ","type":"text"},{"type":"codeVoice","code":"context.calendar"},{"text":" when formatting the date so its locale and time zone stay consistent with the visible calendar. When these closures are omitted, the package preserves SwiftUI’s default day-number announcement. Selected dates also use the system selected accessibility trait.","type":"text"}]}],"kind":"content"}],"variants":[{"paths":["\/documentation\/recordscalendarui"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"doc://recordscalendarui.RecordsCalendarUI/documentation/RecordsCalendarUI/RecordsCalendarConfiguration":{"type":"topic","navigatorTitle":[{"kind":"identifier","text":"RecordsCalendarConfiguration"}],"kind":"symbol","identifier":"doc:\/\/recordscalendarui.RecordsCalendarUI\/documentation\/RecordsCalendarUI\/RecordsCalendarConfiguration","abstract":[],"role":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"RecordsCalendarConfiguration"}],"url":"\/documentation\/recordscalendarui\/recordscalendarconfiguration","title":"RecordsCalendarConfiguration"},"doc://recordscalendarui.RecordsCalendarUI/documentation/RecordsCalendarUI/RecordsCalendarBestValueComparator":{"type":"topic","navigatorTitle":[{"text":"RecordsCalendarBestValueComparator","kind":"identifier"}],"abstract":[],"identifier":"doc:\/\/recordscalendarui.RecordsCalendarUI\/documentation\/RecordsCalendarUI\/RecordsCalendarBestValu