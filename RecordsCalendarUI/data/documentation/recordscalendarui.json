{"schemaVersion":{"major":0,"patch":0,"minor":3},"metadata":{"title":"RecordsCalendarUI","externalID":"RecordsCalendarUI","symbolKind":"module","role":"collection","modules":[{"name":"RecordsCalendarUI"}],"roleHeading":"Framework"},"abstract":[{"type":"text","text":"Reusable SwiftUI calendar records UI for apps that own their own data, persistence, and navigation."}],"hierarchy":{"paths":[[]]},"sections":[],"kind":"symbol","identifier":{"interfaceLanguage":"swift","url":"doc:\/\/recordscalendarui.RecordsCalendarUI\/documentation\/RecordsCalendarUI"},"topicSections":[{"anchor":"Calendar-Presentation","title":"Calendar Presentation","identifiers":["doc:\/\/recordscalendarui.RecordsCalendarUI\/documentation\/RecordsCalendarUI\/RecordsCalendarView","doc:\/\/recordscalendarui.RecordsCalendarUI\/documentation\/RecordsCalendarUI\/RecordsCalendarConfiguration","doc:\/\/recordscalendarui.RecordsCalendarUI\/documentation\/RecordsCalendarUI\/RecordsCalendarTheme","doc:\/\/recordscalendarui.RecordsCalendarUI\/documentation\/RecordsCalendarUI\/RecordsCalendarDisplayScope"]},{"anchor":"Record-Model-Boundary","title":"Record Model Boundary","identifiers":["doc:\/\/recordscalendarui.RecordsCalendarUI\/documentation\/RecordsCalendarUI\/RecordsCalendarEntry"]},{"anchor":"Structures","title":"Structures","generated":true,"identifiers":["doc:\/\/recordscalendarui.RecordsCalendarUI\/documentation\/RecordsCalendarUI\/RecordsCalendarBestValueComparator","doc:\/\/recordscalendarui.RecordsCalendarUI\/documentation\/RecordsCalendarUI\/RecordsCalendarDayAccessibilityContext"]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/recordscalendarui"]}],"primaryContentSections":[{"kind":"content","content":[{"anchor":"Overview","level":2,"type":"heading","text":"Overview"},{"inlineContent":[{"code":"RecordsCalendarUI","type":"codeVoice"},{"text":" provides presentation-only calendar components for record-based apps. Host apps pass records, display configuration, selection state, and callbacks while keeping storage and detail navigation outside the package.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Use this package when you need a reusable week\/month calendar with a selected-day list and swipe-to-delete behavior, but each app needs different record values, text formatting, and detail screens.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"code":"RecordsCalendarConfiguration.rowHeight","type":"codeVoice"},{"text":" controls the minimum selected-day row card height. ","type":"text"},{"code":"RecordsCalendarConfiguration.rowSpacing","type":"codeVoice"},{"text":" controls the vertical spacing between selected-day rows, defaults to 5 points, can be customized by host apps, and clamps negative values to zero. Values below ","type":"text"},{"code":"RecordsCalendarConfiguration<YourRecord>.minimumRowHeight","type":"codeVoice"},{"text":", currently 44 points, are clamped so row content keeps a standard touch target. Row spacing does not reduce the configured row height. ","type":"text"},{"code":"RecordsCalendarConfiguration<YourRecord>.minimumRowHeight(forRowSpacing:)","type":"codeVoice"},{"text":" remains as a deprecated compatibility helper; use ","type":"text"},{"code":"minimumRowHeight","type":"codeVoice"},{"text":" for new code.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"code":"RecordsCalendarConfiguration.theme","type":"codeVoice"},{"text":" accepts semantic colors through ","type":"text"},{"code":"RecordsCalendarTheme","type":"codeVoice"},{"text":", including the full-page background, calendar and record container background, primary and secondary page content colors, optional container-only primary and secondary content colors, and independent light and dark summary tile backgrounds. The default ","type":"text"},{"code":".standard","type":"codeVoice"},{"text":" theme preserves the system grouped page background, material calendar container, grouped record containers, and existing green appearance. Host apps can supply adaptive SwiftUI colors without changing package internals.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Theme initialization without an explicit light-mode secondary content color remains supported and derives that color from ","type":"text"},{"code":"contentColor","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"To change only surfaces, copy ","type":"text"},{"code":".standard","type":"codeVoice"},{"text":" and set ","type":"text"},{"code":"backgroundColor","type":"codeVoice"},{"text":" or ","type":"text"},{"code":"containerBackgroundColor","type":"codeVoice"},{"text":". The package applies the container color consistently to the calendar, selected-day empty state, and record rows. Set ","type":"text"},{"code":"containerContentColor","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"containerSecondaryContentColor","type":"codeVoice"},{"text":" when those containers need a foreground palette that differs from the page. Selected calendar days continue to use the page primary content color so it remains paired with ","type":"text"},{"code":"selectedDayBackgroundColor","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Calendar day buttons can receive an accessibility label and value from ","type":"text"},{"code":"RecordsCalendarConfiguration","type":"codeVoice"},{"text":". The package passes a ","type":"text"},{"code":"RecordsCalendarDayAccessibilityContext","type":"codeVoice"},{"text":" with the date, its display calendar, and the today, selected, and has-records states so host apps can provide their own localized full-date label and state text. Use ","type":"text"},{"code":"context.calendar","type":"codeVoice"},{"text":" when formatting the date so its locale and time zone stay consistent with the visible calendar. When these closures are omitted, the package preserves SwiftUI’s default day-number announcement. Selected dates also use the system selected accessibility trait.","type":"text"}],"type":"paragraph"}]}],"references":{"doc://recordscalendarui.RecordsCalendarUI/documentation/RecordsCalendarUI/RecordsCalendarDayAccessibilityContext":{"identifier":"doc:\/\/recordscalendarui.RecordsCalendarUI\/documentation\/RecordsCalendarUI\/RecordsCalendarDayAccessibilityContext","url":"\/documentation\/recordscalendarui\/recordscalendardayaccessibilitycontext","abstract":[],"title":"RecordsCalendarDayAccessibilityContext","type":"topic","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"RecordsCalendarDayAccessibilityContext"}],"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"RecordsCalendarDayAccessibilityContext"}],"kind":"symbol"},"doc://recordscalendarui.RecordsCalendarUI/documentation/RecordsCalendarUI/RecordsCalendarBestValueComparator":{"navigatorTitle":[{"kind":"identifier","text":"RecordsCalendarBestValueComparator"}],"title":"RecordsCalendarBestValueComparator","type":"topic","abstract":[],"url":"\/documentation\/recordscalendarui\/recordscalendarbestvaluecomparator","role":"symbol","kind":"symbol","identifier":"doc:\/\/recordscalendarui.RecordsCalendarUI\/documentation\/RecordsCalendarUI\/RecordsCalendarBestValueComparator","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"RecordsCalendarBestValueComparator"}]},"doc://recordscalendarui.RecordsCalendarUI/documentation/RecordsCalendarUI/RecordsCalendarConfiguration":{"identifier":"doc:\/\/recordscalendarui.RecordsCalendarUI\/documentation\/RecordsCalendarUI\/RecordsCalendarConfiguration","abstract":[],"url":"\/documentation\/recordscalendarui\/recordscalendarconfiguration","title":"RecordsCalendarConfiguration","type":"topic","role":"symbol","navigatorTitle":[{"text":"RecordsCalendarConfiguration","kind":"identifier"}],"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"RecordsCalendarConfiguration","kind":"identifier"}],"kind":"symbol"},"doc://recordscalendarui.RecordsCalendarUI/documentation/RecordsCalendarUI/RecordsCalendarTheme":{"type":"topic","abstract":[],"identifier":"doc:\/\/recordscalendarui.RecordsCalendarUI\/documentation\/RecordsCalendarUI\/RecordsCalendarTheme","role":"symbol","navigatorTitle":[{"text":"RecordsCalendarTheme","kind":"identifier"}],"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"RecordsCalendarTheme","kind":"identifier"}],"kind":"symbol","url":"\/documentation\/recordscalendarui\/recordscalendartheme","title":"RecordsCalendarTheme"},"doc://recordscalendarui.RecordsCalendarUI/documentation/RecordsCalendarUI/RecordsCalendarView":{"type":"topic","abstract":[],"identifier":"doc:\/\/recordscalendarui.RecordsCalendarUI\/documentation\/RecordsCalendarUI\/RecordsCalendarView","role":"symbol","navigatorTitle":[{"text":"RecordsCalendarView","kind":"identifier"}],"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"RecordsCalendarView","kind":"identifier"}],"kind":"symbol","url":"\/documentation\/recordscalendarui\/recordscalendarview","title":"RecordsCalendarView"},"doc://recordscalendarui.RecordsCalendarUI/documentation/RecordsCalendarUI/RecordsCalendarDisplayScope":{"identifier":"doc:\/\/recordscalendarui.RecordsCalendarUI\/documentation\/RecordsCalendarUI\/RecordsCalendarDisplayScope","url":"\/documentation\/recordscalendarui\/recordscalendardisplayscope","abstract":[],"title":"RecordsCalendarDisplayScope","type":"topic","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"RecordsCalendarDisplayScope"}],"fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"RecordsCalendarDisplayScope"}],"kind":"symbol"},"doc://recordscalendarui.RecordsCalendarUI/documentation/RecordsCalendarUI/RecordsCalendarEntry":{"navigatorTitle":[{"kind":"identifier","text":"RecordsCalendarEntry"}],"title":"RecordsCalendarEntry","type":"topic","abstract":[],"url":"\/documentation\/recordscalendarui\/recordscalendarentry","role":"symbol","kind":"symbol","identifier":"doc:\/\/recordscalendarui.RecordsCalendarUI\/documentation\/RecordsCalendarUI\/RecordsCalendarEntry","fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"RecordsCalendarEntry"}]},"doc://recordscalendarui.RecordsCalendarUI/documentation/RecordsCalendarUI":{"type":"topic","abstract":[{"text":"Reusable SwiftUI calendar records UI for apps that own their own data, persistence, and navigation.","type":"text"}],"identifier":"doc:\/\/recordscalendarui.RecordsCalendarUI\/documentation\/RecordsCalendarUI","role":"collection","kind":"symbol","url":"\/documentation\/recordscalendarui","title":"RecordsCalendarUI"}}}