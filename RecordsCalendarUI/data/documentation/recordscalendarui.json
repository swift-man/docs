guration","kind":"identifier"}],"kind":"symbol","type":"topic","url":"\/documentation\/recordscalendarui\/recordscalendarconfiguration","title":"RecordsCalendarConfiguration","identifier":"doc:\/\/recordscalendarui.RecordsCalendarUI\/documentation\/RecordsCalendarUI\/RecordsCalendarConfiguration","abstract":[],"role":"symbol"},"doc://recordscalendarui.RecordsCalendarUI/documentation/RecordsCalendarUI/RecordsCalendarEntry":{"type":"topic","title":"RecordsCalendarEntry","kind":"symbol","url":"\/documentation\/recordscalendarui\/recordscalendarentry","abstract":[],"identifier":"doc:\/\/recordscalendarui.RecordsCalendarUI\/documentation\/RecordsCalendarUI\/RecordsCalendarEntry","navigatorTitle":[{"kind":"identifier","text":"RecordsCalendarEntry"}],"role":"symbol","fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"RecordsCalendarEntry"}]},"doc://recordscalendarui.RecordsCalendarUI/documentation/RecordsCalendarUI/RecordsCalendarDayAccessibilityContext":{"fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"kind":"identifier","text":"RecordsCalendarDayAccessibilityContext"}],"navigatorTitle":[{"kind":"identifier","text":"RecordsCalendarDayAccessibilityContext"}],"kind":"symbol","type":"topic","url":"\/documentation\/recordscalendarui\/recordscalendardayaccessibilitycontext","title":"RecordsCalendarDayAccessibilityContext","identifier":"doc:\/\/recordscalendarui.RecordsCalendarUI\/documentation\/RecordsCalendarUI\/RecordsCalendarDayAccessibilityContext","abstract":[],"role":"symbol"},"doc://recordscalendarui.RecordsCalendarUI/documentation/RecordsCalendarUI/RecordsCalendarWeekTitleContext":{"url":"\/documentation\/recordscalendarui\/recordscalendarweektitlecontext","navigatorTitle":[{"kind":"identifier","text":"RecordsCalendarWeekTitleContext"}],"role":"symbol","kind":"symbol","type":"topic","abstract":[],"identifier":"doc:\/\/recordscalendarui.RecordsCalendarUI\/documentation\/RecordsCalendarUI\/