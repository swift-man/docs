{"hierarchy":{"paths":[[]]},"metadata":{"role":"collection","symbolKind":"module","externalID":"RecordsCalendarUI","title":"RecordsCalendarUI","modules":[{"name":"RecordsCalendarUI"}],"roleHeading":"Framework"},"topicSections":[{"anchor":"Calendar-Presentation","title":"Calendar Presentation","identifiers":["doc:\/\/recordscalendarui.RecordsCalendarUI\/documentation\/RecordsCalendarUI\/RecordsCalendarView","doc:\/\/recordscalendarui.RecordsCalendarUI\/documentation\/RecordsCalendarUI\/RecordsCalendarConfiguration","doc:\/\/recordscalendarui.RecordsCalendarUI\/documentation\/RecordsCalendarUI\/RecordsCalendarTheme","doc:\/\/recordscalendarui.RecordsCalendarUI\/documentation\/RecordsCalendarUI\/RecordsCalendarDisplayScope"]},{"anchor":"Record-Model-Boundary","title":"Record Model Boundary","identifiers":["doc:\/\/recordscalendarui.RecordsCalendarUI\/documentation\/RecordsCalendarUI\/RecordsCalendarEntry"]},{"anchor":"Structures","title":"Structures","identifiers":["doc:\/\/recordscalendarui.RecordsCalendarUI\/documentation\/RecordsCalendarUI\/RecordsCalendarBestValueComparator","doc:\/\/recordscalendarui.RecordsCalendarUI\/documentation\/RecordsCalendarUI\/RecordsCalendarDayAccessibilityContext"],"generated":true}],"sections":[],"primaryContentSections":[{"kind":"content","content":[{"type":"heading","level":2,"text":"Overview","anchor":"Overview"},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"RecordsCalendarUI"},{"text":" provides presentation-only calendar components for record-based apps. Host apps pass records, display configuration, selection state, and callbacks while keeping storage and detail navigation outside the package.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use this package when you need a reusable week\/month calendar with a selected-day list and swipe-to-delete behavior, but each app needs different record values, text formatting, and detail screens."}]},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"RecordsCalendarConfiguration.rowHeight"},{"type":"text","text":" controls the minimum selected-day row card height. "},{"type":"codeVoice","code":"RecordsCalendarConfiguration.rowSpacing"},{"type":"text","text":" controls the vertical spacing between selected-day rows, defaults to 5 points, can be customized by host apps, and clamps negative values to zero. Values below "},{"type":"codeVoice","code":"RecordsCalendarConfiguration<YourRecord>.minimumRowHeight"},{"type":"text","text":", currently 44 points, are clamped so row content keeps a standard touch target. Row spacing does not reduce the configured row height. "},{"type":"codeVoice","code":"RecordsCalendarConfiguration<YourRecord>.minimumRowHeight(forRowSpacing:)"},{"type":"text","text":" remains as a deprecated compatibility helper; use "},{"type":"codeVoice","code":"minimumRowHeight"},{"type":"text","text":" for new code."}]},{"type":"paragraph","inlineContent":[{"code":"RecordsCalendarConfiguration.theme","type":"codeVoice"},{"text":" accepts semantic colors through ","type":"text"},{"code":"RecordsCalendarTheme","type":"codeVoice"},{"text":", including the full-page background, calendar and record container background, primary and secondary content colors, and independent light and dark summary tile backgrounds. The default ","type":"text"},{"code":".standard","type":"codeVoice"},{"text":" theme preserves the system grouped page background, material calendar container, grouped record containers, and existing green appearance. Host apps can supply adaptive SwiftUI colors without changing package internals.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Theme initialization without an explicit light-mode secondary content color remains supported and derives that color from ","type":"text"},{"type":"codeVoice","code":"contentColor"},{"text":".","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"To change only surfaces, copy ","type":"text"},{"code":".standard","type":"codeVoice"},{"text":" and set ","type":"text"},{"code":"backgroundColor","type":"codeVoice"},{"text":" or ","type":"text"},{"code":"containerBackgroundColor","type":"codeVoice"},{"text":". The package applies the container color consistently to the calendar, selected-day empty state, and record rows.","type":"text"}]},{"inlineContent":[{"text":"Calendar day buttons can receive an accessibility label and value from ","type":"text"},{"code":"RecordsCalendarConfiguration","type":"codeVoice"},{"text":". The package passes a ","type":"text"},{"code":"RecordsCalendarDayAccessibilityContext","type":"codeVoice"},{"text":" with the date, its display calendar, and the today, selected, and has-records states so host apps can provide their own localized full-date label and state text. Use ","type":"text"},{"code":"context.calendar","type":"codeVoice"},{"text":" when formatting the date so its locale and time zone stay consistent with the visible calendar. When these closures are omitted, the package preserves SwiftUI’s default day-number announcement. Selected dates also use the system selected accessibility trait.","type":"text"}],"type":"paragraph"}]}],"abstract":[{"type":"text","text":"Reusable SwiftUI calendar records UI for apps that own their own data, persistence, and navigation."}],"schemaVersion":{"major":0,"minor":3,"patch":0},"kind":"symbol","identifier":{"url":"doc:\/\/recordscalendarui.RecordsCalendarUI\/documentation\/RecordsCalendarUI","interfaceLanguage":"swift"},"variants":[{"paths":["\/documentation\/recordscalendarui"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"doc://recordscalendarui.RecordsCalendarUI/documentation/RecordsCalendarUI/RecordsCalendarDayAccessibilityContext":{"title":"RecordsCalendarDayAccessibilityContext","identifier":"doc:\/\/recordscalendarui.RecordsCalendarUI\/documentation\/RecordsCalendarUI\/RecordsCalendarDayAccessibilityContext","role":"symbol","abstract":[],"fragments":[{"text":"struct","kind":"keyword"},{"tex