{"schemaVersion":{"major":0,"patch":0,"minor":3},"abstract":[{"text":"Reusable SwiftUI calendar records UI for apps that own their own data, persistence, and navigation.","type":"text"}],"hierarchy":{"paths":[[]]},"kind":"symbol","sections":[],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/recordscalendarui.RecordsCalendarUI\/documentation\/RecordsCalendarUI"},"topicSections":[{"title":"Calendar Presentation","identifiers":["doc:\/\/recordscalendarui.RecordsCalendarUI\/documentation\/RecordsCalendarUI\/RecordsCalendarView","doc:\/\/recordscalendarui.RecordsCalendarUI\/documentation\/RecordsCalendarUI\/RecordsCalendarConfiguration","doc:\/\/recordscalendarui.RecordsCalendarUI\/documentation\/RecordsCalendarUI\/RecordsCalendarTheme","doc:\/\/recordscalendarui.RecordsCalendarUI\/documentation\/RecordsCalendarUI\/RecordsCalendarDisplayScope"],"anchor":"Calendar-Presentation"},{"title":"Record Model Boundary","identifiers":["doc:\/\/recordscalendarui.RecordsCalendarUI\/documentation\/RecordsCalendarUI\/RecordsCalendarEntry"],"anchor":"Record-Model-Boundary"},{"generated":true,"title":"Structures","identifiers":["doc:\/\/recordscalendarui.RecordsCalendarUI\/documentation\/RecordsCalendarUI\/RecordsCalendarBestValueComparator","doc:\/\/recordscalendarui.RecordsCalendarUI\/documentation\/RecordsCalendarUI\/RecordsCalendarDayAccessibilityContext"],"anchor":"Structures"}],"primaryContentSections":[{"content":[{"level":2,"text":"Overview","type":"heading","anchor":"Overview"},{"inlineContent":[{"code":"RecordsCalendarUI","type":"codeVoice"},{"text":" provides presentation-only calendar components for record-based apps. Host apps pass records, display configuration, selection state, and callbacks while keeping storage and detail navigation outside the package.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Use this package when you need a reusable week\/month calendar with a selected-day list and swipe-to-delete behavior, but each app needs different record values, text formatting, and detail screens.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"code":"RecordsCalendarConfiguration.rowHeight","type":"codeVoice"},{"text":" controls the minimum selected-day row card height. ","type":"text"},{"code":"RecordsCalendarConfiguration.rowSpacing","type":"codeVoice"},{"text":" controls the vertical spacing between selected-day rows, defaults to 5 points, can be customized by host apps, and clamps negative values to zero. Values below ","type":"text"},{"code":"RecordsCalendarConfiguration<YourRecord>.minimumRowHeight","type":"codeVoice"},{"text":", currently 44 points, are clamped so row content keeps a standard touch target. Row spacing does not reduce the configured row height. ","type":"text"},{"code":"RecordsCalendarConfiguration<YourRecord>.minimumRowHeight(forRowSpacing:)","type":"codeVoice"},{"text":" remains as a deprecated compatibility helper; use ","type":"text"},{"code":"minimumRowHeight","type":"codeVoice"},{"text":" for new code.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"code":"RecordsCalendarConfiguration.theme","type":"codeVoice"},{"text":" accepts semantic summary and calendar colors through ","type":"text"},{"code":"RecordsCalendarTheme","type":"codeVoice"},{"text":", including independent dark-mode summary content and light and dark summary tile backgrounds. The default ","type":"text"},{"code":".standard","type":"codeVoice"},{"text":" theme preserves the existing green appearance while host apps can supply brand colors without changing package internals.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Calendar day buttons can receive an accessibility label and value from ","type":"text"},{"code":"RecordsCalendarConfiguration","type":"codeVoice"},{"text":". The package passes a ","type":"text"},{"code":"RecordsCalendarDayAccessibilityContext","type":"codeVoice"},{"text":" with the date, its display calendar, and the today, selected, and has-records states so host apps can provide their own localized full-date label and state text. Use ","type":"text"},{"code":"context.calendar","type":"codeVoice"},{"text":" when formatting the date so its locale and time zone stay consistent with the visible calendar. When these closures are omitted, the package preserves SwiftUI’s default day-number announcement. Selected dates also use the system selected accessibility trait.","type":"text"}],"type":"paragraph"}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/recordscalendarui"]}],"metadata":{"title":"RecordsCalendarUI","role":"collection","modules":[{"name":"RecordsCalendarUI"}],"externalID":"RecordsCalendarUI","roleHeading":"Framework","symbolKind":"module"},"references":{"doc://recordscalendarui.RecordsCalendarUI/documentation/RecordsCalendarUI/RecordsCalendarBestValueComparator":{"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"RecordsCalendarBestValueComparator"}],"title":"RecordsCalendarBestValueComparator","url":"\/documentation\/recordscalendarui\/recordscalendarbestvaluecomparator","abstract":[],"kind":"symbol","type":"topic","identifier":"doc:\/\/recordscalendarui.RecordsCalendarUI\/documentation\/RecordsCalendarUI\/RecordsCalendarBestValueComparator","navigatorTitle":[{"kind":"identifier","text":"RecordsCalendarBestValueComparator"}],"role":"symbol"},"doc://recordscalendarui.RecordsCalendarUI/documentation/RecordsCalendarUI/RecordsCalendarTheme":{"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"RecordsCalendarTheme"}],"title":"RecordsCalendarTheme","url":"\/documentation\/recordscalendarui\/recordscalendartheme","abstract":[],"kind":"symbol","type":"topic","identifier":"doc:\/\/recordscalendarui.RecordsCalendarUI\/documentation\/RecordsCalendarUI\/RecordsCalendarTheme","navigatorTitle":[{"kind":"identifier","text":"RecordsCalendarTheme"}],"role":"symbol"},"doc://recor