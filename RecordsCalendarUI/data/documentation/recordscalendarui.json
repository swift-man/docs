{"hierarchy":{"paths":[[]]},"primaryContentSections":[{"content":[{"text":"Overview","level":2,"type":"heading","anchor":"Overview"},{"inlineContent":[{"code":"RecordsCalendarUI","type":"codeVoice"},{"type":"text","text":" provides presentation-only calendar components for record-based apps. Host apps pass records, display configuration, selection state, and callbacks while keeping storage and detail navigation outside the package."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Use this package when you need a reusable week\/month calendar with a selected-day list and swipe-to-delete behavior, but each app needs different record values, text formatting, and detail screens."}],"type":"paragraph"},{"inlineContent":[{"code":"RecordsCalendarConfiguration.rowHeight","type":"codeVoice"},{"type":"text","text":" controls the minimum selected-day row card height. "},{"code":"RecordsCalendarConfiguration.rowSpacing","type":"codeVoice"},{"type":"text","text":" controls the vertical spacing between selected-day rows, defaults to 5 points, can be customized by host apps, and clamps negative values to zero. Values below "},{"code":"RecordsCalendarConfiguration<YourRecord>.minimumRowHeight","type":"codeVoice"},{"type":"text","text":", currently 44 points, are clamped so row content keeps a standard touch target. Row spacing does not reduce the configured row height. "},{"code":"RecordsCalendarConfiguration<YourRecord>.minimumRowHeight(forRowSpacing:)","type":"codeVoice"},{"type":"text","text":" remains as a deprecated compatibility helper; use "},{"code":"minimumRowHeight","type":"codeVoice"},{"type":"text","text":" for new code."}],"type":"paragraph"}],"kind":"content"}],"variants":[{"paths":["\/documentation\/recordscalendarui"],"traits":[{"interfaceLanguage":"swift"}]}],"abstract":[{"text":"Reusable SwiftUI calendar records UI for apps that own their own data, persistence, and navigation.","type":"text"}],"sections":[],"schemaVersion":{"major":0,"minor":3,"patc