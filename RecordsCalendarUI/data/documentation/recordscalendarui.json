{"schemaVersion":{"patch":0,"major":0,"minor":3},"primaryContentSections":[{"content":[{"anchor":"Overview","level":2,"type":"heading","text":"Overview"},{"type":"paragraph","inlineContent":[{"code":"RecordsCalendarUI","type":"codeVoice"},{"text":" provides presentation-only calendar components for record-based apps. Host apps pass records, display configuration, selection state, and callbacks while keeping storage and detail navigation outside the package.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Use this package when you need a reusable week\/month calendar with a selected-day list and swipe-to-delete behavior, but each app needs different record values, text formatting, and detail screens.","type":"text"}]},{"type":"paragraph","inlineContent":[{"code":"RecordsCalendarConfiguration.rowHeight","type":"codeVoice"},{"text":" controls the minimum selected-day list slot height for each row. ","type":"text"},{"code":"RecordsCalendarConfiguration.rowSpacing","type":"codeVoice"},{"text":" controls the vertical spacing between selected-day rows, defaults to 5 points, can be customized by host apps, and clamps negative values to zero. Values below ","type":"text"},{"code":"RecordsCalendarConfiguration<YourRecord>.minimumRowHeight","type":"codeVoice"},{"text":", currently 49 points with the default spacing, are clamped so row content keeps a standard touch target while preserving compact spacing between selected-day rows. For custom spacing, use ","type":"text"},{"code":"RecordsCalendarConfiguration<YourRecord>.minimumRowHeight(forRowSpacing:)","type":"codeVoice"},{"text":" to calculate the matching protected minimum.","type":"text"}]}],"kind":"content"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/recordscalendarui.RecordsCalendarUI\/documentation\/RecordsCalendarUI"},"sections":[],"hierarchy":{"paths":[[]]},"abstract":[{"text":"Reusable SwiftUI calendar records UI for apps that own their own data, persistence, and navigation.","type":"te