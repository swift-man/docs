/recordscalendarui.RecordsCalendarUI/documentation/RecordsCalendarUI/RecordsCalendarEntry":{"type":"topic","url":"\/documentation\/recordscalendarui\/recordscalendarentry","fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"RecordsCalendarEntry","kind":"identifier"}],"title":"RecordsCalendarEntry","navigatorTitle":[{"text":"RecordsCalendarEntry","kind":"identifier"}],"role":"symbol","abstract":[],"identifier":"doc:\/\/recordscalendarui.RecordsCalendarUI\/documentation\/RecordsCalendarUI\/RecordsCalendarEntry","kind":"symbol"},"doc://recordscalendarui.RecordsCalendarUI/documentation/RecordsCalendarUI/RecordsCalendarBestValueComparator":{"url":"\/documentation\/recordscalendarui\/recordscalendarbestvaluecomparator","type":"topic","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"RecordsCalendarBestValueComparator","kind":"identifier"}],"title":"RecordsCalendarBestValueComparator","navigatorTitle":[{"text":"RecordsCalendarBestValueComparator","kind":"identifier"}],"role":"symbol","abstract":[],"identifier":"doc:\/\/recordscalendarui.RecordsCalendarUI\/documentation\/RecordsCalendarUI\/RecordsCalendarBestValueComparator","kind":"symbol"},"doc://recordscalendarui.RecordsCalendarUI/documentation/RecordsCalendarUI/RecordsCalendarView":{"title":"RecordsCalendarView","abstract":[],"role":"symbol","navigatorTitle":[{"text":"RecordsCalendarView","kind":"identifier"}],"url":"\/documentation\/recordscalendarui\/recordscalendarview","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"RecordsCalendarView","kind":"identifier"}],"identifier":"doc:\/\/recordscalendarui.RecordsCalendarUI\/documentation\/RecordsCalendarUI\/RecordsCalendarView","type":"topic","kind":"symbol"},"doc://recordscalendarui.RecordsCalendarUI/documentation/RecordsCalendarUI":{"title":"RecordsCalendarUI","abstract":[{"text":"Reusable SwiftUI calendar records UI for apps that own their own data, persistence, and navigation.","type":"text"}],"role":"collection","url":"\/documentation\/recordscalendarui","kind":"symbol","type":"topic","identifier":"doc:\/\/recordscalendarui.RecordsCalendarUI\/documentation\/RecordsCalendarUI"}}}