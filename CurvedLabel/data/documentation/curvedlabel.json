{"kind":"symbol","schemaVersion":{"minor":3,"major":0,"patch":0},"primaryContentSections":[{"content":[{"type":"heading","text":"Overview","anchor":"Overview","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use "},{"type":"codeVoice","code":"CurvedLabel"},{"type":"text","text":" when a "},{"type":"codeVoice","code":"UILabel"},{"type":"text","text":" needs to render text around a circle, such"},{"type":"text","text":" "},{"type":"text","text":"as badges, dials, stickers, or decorative controls. The label uses its"},{"type":"text","text":" "},{"type":"codeVoice","code":"attributedText"},{"type":"text","text":" when present and falls back to "},{"type":"codeVoice","code":"text"},{"type":"text","text":", "},{"type":"codeVoice","code":"font"},{"type":"text","text":", and "},{"type":"codeVoice","code":"textColor"},{"type":"text","text":" "},{"type":"text","text":"for plain string rendering."}]},{"type":"paragraph","inlineContent":[{"code":"radius","type":"codeVoice"},{"text":" defines the circular path and is clamped to ","type":"text"},{"code":"0","type":"codeVoice"},{"text":" when a negative value","type":"text"},{"text":" ","type":"text"},{"text":"is assigned. When ","type":"text"},{"code":"radius","type":"codeVoice"},{"text":" is greater than ","type":"text"},{"code":"0","type":"codeVoice"},{"text":", Auto Layout uses at least the","type":"text"},{"text":" ","type":"text"},{"text":"circle diameter for ","type":"text"},{"code":"intrinsicContentSize","type":"codeVoice"},{"text":", plus the rendered text’s line height","type":"text"},{"text":" ","type":"text"},{"text":"when text is drawn outside the circle. ","type":"text"},{"code":"rotation","type":"codeVoice"},{"text":" offsets the path in degrees,","type":"text"},{"text":" ","type":"text"},{"text":"and ","type":"text"},{"code":"textInside","type":"codeVoice"},{"text":" chooses whether glyphs sit inside or outside the circle.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"When ","type":"text"},{"code":"attributedText","type":"codeVoice"},{"text":" is set, its own attributes drive rendering. ","type":"text"},{"code":"font","type":"codeVoice"},{"text":" and","type":"text"},{"text":" ","type":"text"},{"code":"textColor","type":"codeVoice"},{"text":" are used for plain ","type":"text"},{"code":"text","type":"codeVoice"},{"text":" fallback; ","type":"text"},{"code":"font","type":"codeVoice"},{"text":" also defines intrinsic","type":"text"},{"text":" ","type":"text"},{"text":"sizing for attributed ranges that omit a font.","type":"text"}]},{"type":"heading","text":"Installation","anchor":"Installation","level":2},{"type":"paragraph","inlineContent":[{"text":"Add CurvedLabel to your Swift package dependencies.","type":"text"}]},{"type":"codeListing","code":["dependencies: [","  .package(url: \"https:\/\/github.com\/swift-man\/CurvedLabel.git\", from: \"1.0.0\")","]"],"syntax":"swift"},{"type":"heading","text":"Basic Usage","anchor":"Basic-Usage","level":2},{"type":"codeListing","code":["import UIKit","import CurvedLabel","","let label = CurvedLabel()","label.frame = CGRect(x: 0, y: 0, width: 300, height: 300)","","label.textColor = .black","label.radius = 120","label.rotation = 180","label.textInside = true","label.attributedText = NSAttributedString(","  string: \"Hello World!\",","  attributes: [","    .foregroundColor: UIColor.black","  ]",")"],"syntax":"swift"}],"kind":"content"}],"variants":[{"paths":["\/documentation\/curvedlabel"],"traits":[{"interfaceLanguage":"swift"}]}],"abstract":[{"type":"text","text":"Draw attributed UIKit text along a circular path."}],"topicSections":[{"title":"Views","identifiers":["doc:\/\/curvedlabel.CurvedLabel\/documentation\/CurvedLabel\/CurvedLabel"],"anchor":"Views"}],"hierarchy":{"paths":[[]]},"metadata":{"modules":[{"name":"CurvedLabel"}],"role":"collection","roleHeading":"Framework","externalID":"CurvedLabel","title":"CurvedLabel","symbolKind":"module"},"sections":[],"identifier":{"interfaceLanguage":"swi