text"},{"text":" ","type":"text"},{"text":"circle diameter for ","type":"text"},{"code":"intrinsicContentSize","type":"codeVoice"},{"text":", plus the rendered text’s line height","type":"text"},{"text":" ","type":"text"},{"text":"when text is drawn outside the circle. ","type":"text"},{"code":"rotation","type":"codeVoice"},{"text":" offsets the path in degrees,","type":"text"},{"text":" ","type":"text"},{"text":"and ","type":"text"},{"code":"textInside","type":"codeVoice"},{"text":" chooses whether glyphs sit inside or outside the circle.","type":"text"}],"type":"paragraph"},{"level":2,"anchor":"Installation","type":"heading","text":"Installation"},{"inlineContent":[{"type":"text","text":"Add CurvedLabel to your Swift package dependencies."}],"type":"paragraph"},{"syntax":"swift","code":["dependencies: [","  .package(url: \"https:\/\/github.com\/swift-man\/CurvedLabel.git\", from: \"1.0.0\")","]"],"type":"codeListing"},{"level":2,"anchor":"Basic-Usage","type":"heading","text":"Basic Usage"},{"syntax":"swift","code":["import UIKit","import CurvedLabel","","let label = CurvedLabel()","label.frame = CGRect(x: 0, y: 0, width: 300, height: 300)","","label.textColor = .black","label.radius = 120","label.rotation = 180","label.textInside = true","label.attributedText = NSAttributedString(","  string: \"Hello World!\",","  attributes: [","    .foregroundColor: UIColor.black","  ]",")"],"type":"codeListing"}]}],"hierarchy":{"paths":[[]]},"references":{"doc://curvedlabel.CurvedLabel/documentation/CurvedLabel/CurvedLabel":{"type":"topic","abstract":[{"text":"A ","type":"text"},{"code":"UILabel","type":"codeVoice"},{"text":" subclass that draws attributed text along a circular arc.","type":"text"}],"url":"\/documentation\/curvedlabel\/curvedlabel","role":"symbol","kind":"symbol","navigatorTitle":[{"text":"CurvedLabel","kind":"identifier"}],"identifier":"doc:\/\/curvedlabel.CurvedLabel\/documentation\/CurvedLabel\/CurvedLabel","title":"CurvedLabel","fragments":[{"text":"class",