{"schemaVersion":{"minor":3,"major":0,"patch":0},"topicSections":[{"title":"Views","identifiers":["doc:\/\/curvedlabel.CurvedLabel\/documentation\/CurvedLabel\/CurvedLabel"],"anchor":"Views"}],"abstract":[{"type":"text","text":"Draw attributed UIKit text along a circular path."}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/curvedlabel"]}],"identifier":{"url":"doc:\/\/curvedlabel.CurvedLabel\/documentation\/CurvedLabel","interfaceLanguage":"swift"},"metadata":{"externalID":"CurvedLabel","symbolKind":"module","modules":[{"name":"CurvedLabel"}],"roleHeading":"Framework","role":"collection","title":"CurvedLabel"},"hierarchy":{"paths":[[]]},"kind":"symbol","primaryContentSections":[{"content":[{"anchor":"Overview","level":2,"text":"Overview","type":"heading"},{"inlineContent":[{"text":"Use ","type":"text"},{"type":"codeVoice","code":"CurvedLabel"},{"text":" when a ","type":"text"},{"type":"codeVoice","code":"UILabel"},{"text":" needs to render text around a circle, such","type":"text"},{"text":" ","type":"text"},{"text":"as badges, dials, stickers, or decorative controls. The label uses its","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"attributedText"},{"text":" when present and falls back to ","type":"text"},{"type":"codeVoice","code":"text"},{"text":", ","type":"text"},{"type":"codeVoice","code":"font"},{"text":", and ","type":"text"},{"type":"codeVoice","code":"textColor"},{"type":"text","text":" "},{"type":"text","text":"for plain string rendering."}],"type":"paragraph"},{"inlineContent":[{"type":"codeVoice","code":"radius"},{"type":"text","text":" defines the circular path and is clamped to "},{"type":"codeVoice","code":"0"},{"type":"text","text":" when a negative value"},{"type":"text","text":" "},{"type":"text","text":"is assigned. When "},{"type":"codeVoice","code":"radius"},{"type":"text","text":" is greater than "},{"type":"codeVoice","code":"0"},{"type":"text","text":", Auto Layout uses at least the"},{"type":"text","text":" "},{"type":"text","text":"circle diameter for "},{"type":"codeVoice","code":"intrinsicContentSize"},{"type":"text","text":", plus the rendered text’s line height"},{"type":"text","text":" "},{"type":"text","text":"when text is drawn outside the circle. "},{"type":"codeVoice","code":"rotation"},{"type":"text","text":" offsets the path in degrees,"},{"type":"text","text":" "},{"type":"text","text":"and "},{"type":"codeVoice","code":"textInside"},{"type":"text","text":" chooses whether glyphs sit inside or outside the circle."}],"type":"paragraph"},{"anchor":"Installation","level":2,"text":"Installation","type":"heading"},{"inlineContent":[{"type":"text","text":"Add CurvedLabel to your Swift package dependencies."}],"type":"paragraph"},{"code":["dependencies: [","  .package(url: \"https:\/\/github.com\/swift-man\/CurvedLabel.git\", from: \"1.0.0\")","]"],"type":"codeListing","syntax":"swift"},{"anchor":"Basic-Usage","level":2,"text":"Basic Usage","type":"heading"},{"code":["import UIKit","import CurvedLabel","","let label = CurvedLabel()","label.frame = CGRect(x: 0, y: 0, width: 300, height: 300)","","label.textColor = .black","label.radius = 120","label.rotation = 180","label.textInside = true","label.attributedText = NSAttributedString(","  string: \"Hello World!\",","  attributes: [","    .foregroundColor: UIColor.black","  ]",")"],"type":"codeListing","syntax":"swift"}],"kind":"content"}],"sections":[],"references":{"doc://curvedlabel.CurvedLabel/documentation/CurvedLabel/CurvedLabel":{"kind":"symbol","url":"\/documentation\/curvedlabel\/curvedlabel","navigatorTitle":[{"text":"CurvedLabel","kind":"identifier"}],"abstract":[{"text":"A ","type":"text"},{"type":"codeVoice","code":"UILabel"},{"text":" subclass that draws attributed text along a circular arc.","type":"text"}],"fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"CurvedLabel","kind":"identifier"}],"identifier":"doc:\/\/curvedlabel.CurvedLabel\/docum