{"schemaVersion":{"patch":0,"major":0,"minor":3},"metadata":{"roleHeading":"Framework","symbolKind":"module","externalID":"CurvedLabel","title":"CurvedLabel","modules":[{"name":"CurvedLabel"}],"role":"collection"},"abstract":[{"text":"Draw attributed UIKit text along a circular path.","type":"text"}],"primaryContentSections":[{"kind":"content","content":[{"level":2,"anchor":"Overview","type":"heading","text":"Overview"},{"type":"paragraph","inlineContent":[{"text":"Use ","type":"text"},{"code":"CurvedLabel","type":"codeVoice"},{"text":" when a ","type":"text"},{"code":"UILabel","type":"codeVoice"},{"text":" needs to render text around a circle, such","type":"text"},{"text":" ","type":"text"},{"text":"as badges, dials, stickers, or decorative controls. The label uses its","type":"text"},{"text":" ","type":"text"},{"code":"attributedText","type":"codeVoice"},{"text":" when present and falls back to ","type":"text"},{"code":"text","type":"codeVoice"},{"text":", ","type":"text"},{"code":"font","type":"codeVoice"},{"text":", and ","type":"text"},{"code":"textColor","type":"codeVoice"},{"text":" ","type":"text"},{"text":"for plain string rendering.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"radius"},{"text":" defines the circular path and is clamped to ","type":"text"},{"type":"codeVoice","code":"0"},{"text":" when a negative value","type":"text"},{"text":" ","type":"text"},{"text":"is assigned. When ","type":"text"},{"type":"codeVoice","code":"radius"},{"text":" is greater than ","type":"text"},{"type":"codeVoice","code":"0"},{"text":", Auto Layout uses at least the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"circle diameter for "},{"code":"intrinsicContentSize","type":"codeVoice"},{"type":"text","text":", plus the rendered text’s line height"},{"type":"text","text":" "},{"type":"text","text":"when text is drawn outside the circle. "},{"code":"rotation","type":"codeVoice"},{"type":"text","text":" offsets the path in degrees,"},{"type":"text","text":" "},{"type":"text","text":"and "},{"code":"textInside","type":"codeVoice"},{"type":"text","text":" chooses whether glyphs sit inside or outside the circle."}]},{"type":"paragraph","inlineContent":[{"text":"When ","type":"text"},{"code":"attributedText","type":"codeVoice"},{"text":" is set, its own attributes drive rendering. ","type":"text"},{"code":"font","type":"codeVoice"},{"text":" and","type":"text"},{"text":" ","type":"text"},{"code":"textColor","type":"codeVoice"},{"text":" are used for plain ","type":"text"},{"code":"text","type":"codeVoice"},{"text":" fallback; ","type":"text"},{"code":"font","type":"codeVoice"},{"text":" also defines intrinsic","type":"text"},{"text":" ","type":"text"},{"text":"sizing for attributed ranges that omit a font.","type":"text"}]},{"level":2,"anchor":"Installation","type":"heading","text":"Installation"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Add CurvedLabel to your Swift package dependencies."}]},{"code":["dependencies: [","  .package(url: \"https:\/\/github.com\/swift-man\/CurvedLabel.git\", from: \"1.0.0\")","]"],"syntax":"swift","type":"codeListing"},{"level":2,"anchor":"Basic-Usage","type":"heading","text":"Basic Usage"},{"code":["import UIKit","import CurvedLabel","","let label = CurvedLabel()","label.frame = CGRect(x: 0, y: 0, width: 300, height: 300)","","label.textColor = .black","label.radius = 120","label.rotation = 180","label.textInside = true","label.attributedText = NSAttributedString(","  string: \"Hello World!\",","  attributes: [","    .foregroundColor: UIColor.black","  ]",")"],"syntax":"swift","type":"codeListing"}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/curvedlabel.CurvedLabel\/documentation\/CurvedLabel"},"topicSections":[{"identifiers":["doc:\/\/curvedlabel.CurvedLabel\/documentation\/CurvedLabel\/CurvedLabel"],"anchor":"Views","title":"Views"}],"kind":"symbol","sections":[],"hierarchy":{"paths":[[]]},"variants":[{"traits":[{