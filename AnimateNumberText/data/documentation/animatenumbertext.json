{"abstract":[{"type":"text","text":"Animate numeric text changes with rolling digits in SwiftUI."}],"hierarchy":{"paths":[[]]},"identifier":{"url":"doc:\/\/com.swift-man.AnimateNumberText\/documentation\/AnimateNumberText","interfaceLanguage":"swift"},"sections":[],"topicSections":[{"title":"Views","identifiers":["doc:\/\/com.swift-man.AnimateNumberText\/documentation\/AnimateNumberText\/AnimateNumberText"],"anchor":"Views"},{"title":"Formatting","identifiers":["doc:\/\/com.swift-man.AnimateNumberText\/documentation\/AnimateNumberText\/AnimateNumberTextFormatter"],"anchor":"Formatting"},{"title":"Animation","identifiers":["doc:\/\/com.swift-man.AnimateNumberText\/documentation\/AnimateNumberText\/AnimateNumberTextAnimation"],"anchor":"Animation"}],"schemaVersion":{"major":0,"patch":0,"minor":3},"kind":"symbol","metadata":{"externalID":"AnimateNumberText","modules":[{"name":"AnimateNumberText"}],"roleHeading":"Framework","role":"collection","title":"AnimateNumberText","symbolKind":"module"},"primaryContentSections":[{"kind":"content","content":[{"text":"Overview","level":2,"type":"heading","anchor":"Overview"},{"inlineContent":[{"text":"Use ","type":"text"},{"code":"AnimateNumberText","type":"codeVoice"},{"text":" when a ","type":"text"},{"code":"Double","type":"codeVoice"},{"type":"text","text":" value should update visually instead of changing as a static string. The view splits the formatted value into characters, animates numeric digits vertically, and renders non-numeric characters such as currency symbols, commas, decimal points, spaces, and suffixes as text."}],"type":"paragraph"},{"inlineContent":[{"text":"The package supports ","type":"text"},{"type":"codeVoice","code":"NumberFormatter"},{"type":"text","text":" for localized number formatting and an optional string format for appending units such as "},{"type":"codeVoice","code":"\"ms\""},{"type":"text","text":" or "},{"type":"codeVoice","code":"\"원\""},{"type":"text","text":"."}],"type":"paragraph"},{"text":"Installation","level":2,"type":"heading","anchor":"Installation"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Add AnimateNumberText to your Swift package dependencies."}]},{"syntax":"swift","code":["dependencies: [","  .package(url: \"https:\/\/github.com\/swift-man\/AnimateNumberText.git\", from: \"0.7.2\")","]"],"type":"codeListing"},{"text":"Basic Usage","level":2,"type":"heading","anchor":"Basic-Usage"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Bind a numeric value and text color to "},{"type":"codeVoice","code":"AnimateNumberText"},{"type":"text","text":"."}]},{"syntax":"swift","code":["import SwiftUI","import AnimateNumberText","","struct ContentView: View {","  @State private var value = 58.09","  @State private var textColor = Color.green","","  var body: some View {","    VStack {","      AnimateNumberText(","        font: .system(size: 55),","        weight: .black,","        value: $value,","        textColor: $textColor","      )","","      Button(\"Change Value\") {","        value += 1","      }","    }","  }","}"],"type":"codeListing"},{"text":"Number Formatting","level":2,"type":"heading","anchor":"Number-Formatting"},{"type":"paragraph","inlineContent":[{"text":"Without a custom formatter, ","type":"text"},{"code":"AnimateNumberText","type":"codeVoice"},{"text":" keeps fractional digits from","type":"text"},{"text":" ","type":"text"},{"code":"Double","type":"codeVoice"},{"text":" values and does not add grouping separators. Pass a ","type":"text"},{"code":"NumberFormatter","type":"codeVoice"},{"text":" ","type":"text"},{"text":"to display currency, localized separators, or explicit fraction digit rules.","type":"text"}]},{"syntax":"swift","code":["import SwiftUI","import AnimateNumberText","","struct PriceView: View {","  @State private var value = 5000000.0","  @State private var textColor = Color.primary","","  private var numberFormatter: NumberFormatter {","    let formatter = NumberFormatter()","    formatter.numberStyle = .currency","    formatter.maximumFractionDigits = 0","    return formatter","  }","","  var body: some View {","    AnimateNumberText(","      value: $value,","      textColor: $textColor,","      numberFormatter: numberFormatter","    )","  }","}"],"type":"codeListing"},{"text":"Read-only Values","level":2,"type":"heading","anchor":"Read-only-Values"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use a plain "},{"type":"codeVoice","code":"Double"},{"type":"text","text":" when the view only needs to display a value and the caller"},{"type":"text","text":" "},{"type":"text","text":"does not need binding-based updates. The default animation is used when"},{"type":"text","text":" "},{"type":"codeVoice","code":"animation"},{"type":"text","text":" is omitted."}]},{"syntax":"swift","code":["import SwiftUI","import AnimateNumberText","","struct SnapshotScoreView: View {","  let value = 10.23","","  var body: some View {","    AnimateNumberText(value: value)","  }","}"],"type":"codeListing"},{"level":2,"type":"heading","anchor":"String-Formatting","text":"String Formatting"},{"inlineContent":[{"text":"Use ","type":"text"},{"code":"stringFormatter","type":"codeVoice"},{"text":" when the formatted number needs a suffix or wrapper.","type":"text"},{"text":" ","type":"text"},{"text":"Prefer a ","type":"text"},{"code":"%@","type":"codeVoice"},{"text":" placeholder such as ","type":"text"},{"code":"\"%@ ms\"","type":"codeVoice"},{"text":" when wrapping the already formatted","type":"text"},{"text":" ","type":"text"},{"text":"display string. Numeric placeholders such as ","type":"text"},{"code":"\"%.2f\"","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"\"%d\"","type":"codeVoice"},{"text":" are applied to","type":"text"},{"text":" ","type":"text"},{"text":"the original ","type":"text"},{"code":"Double","type":"codeVoice"},{"text":" value for compatibility, but ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.swift-man.AnimateNumberText\/documentation\/AnimateNumberText\/AnimateNumberTextFormatter"},{"text":" ","type":"text"},{"text":"with a custom ","type":"text"},{"code":"NumberFormatter","type":"codeVoice"},{"text":" remains the recommended path for currency,","type":"text"},{"text":" ","type":"text"},{"text":"locale, and fraction digit rules.","type":"text"}],"type":"paragraph"},{"code":["import SwiftUI","import AnimateNumberText","","struct LatencyView: View {","  @State private var value = 10.23","  @State private var textColor = Color.primary","","  var body: some View {","    AnimateNumberText(","      value: $value,","      textColor: $textColor,","      stringFormatter: \"%@ ms\"","    )","  }","}"],"type":"codeListing","syntax":"swift"},{"level":2,"type":"heading","anchor":"Animation-Timing","text":"Animation Timing"},{"inlineContent":[{"text":"The default animation uses ","type":"text"},{"code":".smooth(duration:)","type":"codeVoice"},{"text":", a critically damped spring that","type":"text"},{"text":" ","type":"text"},{"text":"accelerates then decelerates while preserving in-flight velocity. Pass an","type":"text"},{"text":" ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.swift-man.AnimateNumberText\/documentation\/AnimateNumberText\/AnimateNumberTextAnimation"},{"text":" value when the smooth rolling duration needs to","type":"text"},{"text":" ","type":"text"},{"text":"be customized or when a rolling digit animation is preferred.","type":"text"}],"type":"paragraph"},{"code":["import SwiftUI","import AnimateNumberText","","struct ScoreView: View {","  @State private var value = 120.0","  @State private var textColor = Color.primary","","  var body: some View {","    AnimateNumberText(","      value: $value,","      textColor: $textColor,","      animation: .smooth(duration: 0.5)","    )","  }","}"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"text":"Use ","type":"text"},{"code":".reel(spinningDuration:settleDuration:revolutions:)","type":"codeVoice"},{"text":" to make each digit spin through 0…9","type":"text"},{"text":" ","type":"text"},{"text":"before settling. Digit columns start together, alternate direction from left to","type":"text"},{"text":" ","type":"text"},{"text":"right, and stop sequentially by the settle duration. ","type":"text"},{"code":"spinningDuration","type":"codeVoice"},{"text":" is the","type":"text"},{"text":" ","type":"text"},{"text":"time the first digit spins before settling.","type":"text"}],"type":"paragraph"},{"code":["AnimateNumberText(","  value: $value,","  textColor: $textColor,","  stringFormatter: \"%@ ms\",","  animation: .reel(spinningDuration: 1.5,","                   settleDuration: 0.25,","                   revolutions: 1)",")"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"text":"For values updated at high frequency, such as drag gestures or timers, throttle","type":"text"},{"text":" ","type":"text"},{"text":"or debounce the bound value at the call site when every intermediate value does","type":"text"},{"text":" ","type":"text"},{"text":"not need to be rendered.","type":"text"}],"type":"paragraph"},{"level":2,"type":"heading","anchor":"Custom-Font-Clipping","text":"Custom Font Clipping"},{"inlineContent":[{"text":"Some script or brush fonts draw glyphs outside their measured digit column. Use","type":"text"},{"text":" ","type":"text"},{"code":"glyphBleed","type":"codeVoice"},{"text":" to give each digit column extra clipping space without changing the","type":"text"},{"text":" ","type":"text"},{"text":"default layout for regular fonts.","type":"text"}],"type":"paragraph"},{"code":["AnimateNumberText(","  font: .custom(\"SignPainter\", size: 48),","  value: $value,","  textColor: $textColor,","  glyphBleed: EdgeInsets(top: 2,","                         leading: 4,","                         bottom: 2,","                         trailing: 4)",")"],"type":"codeListing","syntax":"swift"}]}],"variants":[{"paths":["\/documentat