{"schemaVersion":{"minor":3,"major":0,"patch":0},"hierarchy":{"paths":[[]]},"primaryContentSections":[{"content":[{"anchor":"Overview","text":"Overview","level":2,"type":"heading"},{"inlineContent":[{"text":"Use ","type":"text"},{"code":"AnimateNumberText","type":"codeVoice"},{"text":" when a ","type":"text"},{"code":"Double","type":"codeVoice"},{"text":" value should update visually instead of changing as a static string. The view splits the formatted value into characters, animates numeric digits vertically, and renders non-numeric characters such as currency symbols, commas, decimal points, spaces, and suffixes as text.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The package supports "},{"type":"codeVoice","code":"NumberFormatter"},{"type":"text","text":" for localized number formatting and an optional string format for appending units such as "},{"type":"codeVoice","code":"\"ms\""},{"type":"text","text":" or "},{"type":"codeVoice","code":"\"원\""},{"type":"text","text":"."}],"type":"paragraph"},{"anchor":"Installation","text":"Installation","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"Add AnimateNumberText to your Swift package dependencies."}],"type":"paragraph"},{"code":["dependencies: [","  .package(url: \"https:\/\/github.com\/swift-man\/AnimateNumberText.git\", from: \"0.7.0\")","]"],"type":"codeListing","syntax":"swift"},{"anchor":"Basic-Usage","text":"Basic Usage","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"Bind a numeric value and text color to "},{"type":"codeVoice","code":"AnimateNumberText"},{"type":"text","text":"."}],"type":"paragraph"},{"code":["import SwiftUI","import AnimateNumberText","","struct ContentView: View {","  @State private var value = 58.09","  @State private var textColor = Color.green","","  var body: some View {","    VStack {","      AnimateNumberText(","        font: .system(size: 55),","        weight: .black,","        value: $value,","        textColor: $textColor","      )","","      Button(\"Change Value\") {","        value += 1","      }","    }","  }","}"],"type":"codeListing","syntax":"swift"},{"anchor":"Number-Formatting","text":"Number Formatting","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"Pass a "},{"type":"codeVoice","code":"NumberFormatter"},{"type":"text","text":" to display currency, decimal separators, or other Foundation formatting styles."}],"type":"paragraph"},{"code":["import SwiftUI","import AnimateNumberText","","struct PriceView: View {","  @State private var value = 5000000.0","  @State private var textColor = Color.primary","","  private var numberFormatter: NumberFormatter {","    let formatter = NumberFormatter()","    formatter.numberStyle = .currency","    formatter.maximumFractionDigits = 0","    return formatter","  }","","  var body: some View {","    AnimateNumberText(","      value: $value,","      textColor: $textColor,","      numberFormatter: numberFormatter","    )","  }","}"],"type":"codeListing","syntax":"swift"},{"anchor":"String-Formatting","text":"String Formatting","level":2,"type":"heading"},{"inlineContent":[{"text":"Use ","type":"text"},{"type":"codeVoice","code":"stringFormatter"},{"text":" when the formatted number needs a suffix or wrapper.","type":"text"}],"type":"paragraph"},{"code":["import SwiftUI","import AnimateNumberText","","struct LatencyView: View {","  @State private var value = 10.23","  @State private var textColor = Color.primary","","  var body: some View {","    AnimateNumberText(","      value: $value,","      textColor: $textColor,","      stringFormatter: \"%@ ms\"","    )","  }","}"],"type":"codeListing","syntax":"swift"},{"anchor":"Animation-Timing","text":"Animation Timing","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"The default animation preserves the original rolling spring behavior. Pass an"},{"type":"text","text":" "},{"identifier":"doc:\/\/com.swift-man.AnimateNumberText\/documentati