{"hierarchy":{"paths":[[]]},"topicSections":[{"anchor":"Views","title":"Views","identifiers":["doc:\/\/com.swift-man.AnimateNumberText\/documentation\/AnimateNumberText\/AnimateNumberText"]},{"anchor":"Formatting","title":"Formatting","identifiers":["doc:\/\/com.swift-man.AnimateNumberText\/documentation\/AnimateNumberText\/AnimateNumberTextFormatter"]},{"anchor":"Animation","title":"Animation","identifiers":["doc:\/\/com.swift-man.AnimateNumberText\/documentation\/AnimateNumberText\/AnimateNumberTextAnimation"]}],"metadata":{"role":"collection","externalID":"AnimateNumberText","symbolKind":"module","roleHeading":"Framework","modules":[{"name":"AnimateNumberText"}],"title":"AnimateNumberText"},"abstract":[{"type":"text","text":"Animate numeric text changes with rolling digits in SwiftUI."}],"schemaVersion":{"minor":3,"major":0,"patch":0},"primaryContentSections":[{"kind":"content","content":[{"type":"heading","anchor":"Overview","text":"Overview","level":2},{"type":"paragraph","inlineContent":[{"text":"Use ","type":"text"},{"type":"codeVoice","code":"AnimateNumberText"},{"text":" when a ","type":"text"},{"type":"codeVoice","code":"Double"},{"text":" value should update visually instead of changing as a static string. The view splits the formatted value into characters, animates numeric digits vertically, and renders non-numeric characters such as currency symbols, commas, decimal points, spaces, and suffixes as text.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"The package supports ","type":"text"},{"type":"codeVoice","code":"NumberFormatter"},{"text":" for localized number formatting and an optional string format for appending units such as ","type":"text"},{"type":"codeVoice","code":"\"ms\""},{"text":" or ","type":"text"},{"type":"codeVoice","code":"\"원\""},{"text":".","type":"text"}]},{"type":"heading","anchor":"Installation","text":"Installation","level":2},{"type":"paragraph","inlineContent":[{"text":"Add AnimateNumberText to your Swift package dependencies.","type":"text"}]},{"type":"codeListing","code":["dependencies: [","  .package(url: \"https:\/\/github.com\/swift-man\/AnimateNumberText.git\", from: \"0.7.0\")","]"],"syntax":"swift"},{"type":"heading","anchor":"Basic-Usage","text":"Basic Usage","level":2},{"type":"paragraph","inlineContent":[{"text":"Bind a numeric value and text color to ","type":"text"},{"type":"codeVoice","code":"AnimateNumberText"},{"text":".","type":"text"}]},{"type":"codeListing","code":["import SwiftUI","import AnimateNumberText","","struct ContentView: View {","  @State private var value = 58.09","  @State private var textColor = Color.green","","  var body: some View {","    VStack {","      AnimateNumberText(","        font: .system(size: 55),","        weight: .black,","        value: $value,","        textColor: $textColor","      )","","      Button(\"Change Value\") {","        value += 1","      }","    }","  }","}"],"syntax":"swift"},{"type":"heading","anchor":"Number-Formatting","text":"Number Formatting","level":2},{"type":"paragraph","inlineContent":[{"text":"Without a custom formatter, ","type":"text"},{"type":"codeVoice","code":"AnimateNumberText"},{"text":" keeps fractional digits from","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"Double"},{"text":" values and does not add grouping separators. Pass a ","type":"text"},{"type":"codeVoice","code":"NumberFormatter"},{"text":" ","type":"text"},{"text":"to display currency, localized separators, or explicit fraction digit rules.","type":"text"}]},{"type":"codeListing","code":["import SwiftUI","import AnimateNumberText","","struct PriceView: View {","  @State private var value = 5000000.0","  @State private var textColor = Color.primary","","  private var numberFormatter: NumberFormatter {","    let formatter = NumberFormatter()","    formatter.numberStyle = .currency","    formatter.maximumFractionDigits = 0","    return formatter","  }","","  var body: some View {","    AnimateNumberText(","      value: $value,","      textColor: $textColor,","      numberFormatter: numberFormatter","    )","  }","}"],"syntax":"swift"},{"type":"heading","anchor":"Read-only-Values","text":"Read-only Values","level":2},{"type":"paragraph","inlineContent":[{"text":"Use a plain ","type":"text"},{"type":"codeVoice","code":"Double"},{"text":" when the view only needs to display a value and the caller","type":"text"},{"text":" ","type":"text"},{"text":"does not need binding-based updates. The default animation is used when","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"animation"},{"text":" is omitted.","type":"text"}]},{"type":"codeListing","code":["import SwiftUI","import AnimateNumberText","","struct SnapshotScoreView: View {","  let value = 10.23","","  var body: some View {","    AnimateNumberText(value: value)","  }","}"],"syntax":"swift"},{"type":"heading","anchor":"String-Formatting","text":"String Formatting","level":2},{"type":"paragraph","inlineContent":[{"text":"Use ","type":"text"},{"type":"codeVoice","code":"stringFormatter"},{"text":" when the formatted number needs a suffix or wrapper.","type":"text"},{"text":" ","type":"text"},{"text":"Prefer a ","type":"text"},{"type":"codeVoice","code":"%@"},{"text":" placeholder such as ","type":"text"},{"type":"codeVoice","code":"\"%@ ms\""},{"text":" when wrapping the already formatted","type":"text"},{"text":" ","type":"text"},{"text":"display string. Numeric placeholders such as ","type":"text"},{"type":"codeVoice","code":"\"%.2f\""},{"text":" and ","type":"text"},{"type":"codeVoice","code":"\"%d\""},{"text":" are applied to","type":"text"},{"text":" ","type":"text"},{"text":"the original ","type":"text"},{"type":"codeVoice","code":"Double"},{"text":" value for compatibility, but ","type":"text"},{"identifier":"doc:\/\/com.swift-man.AnimateNumberText\/documentation\/AnimateNumberText\/AnimateNumberTextFormatter","isActive":true,"type":"reference"},{"text":" ","type":"text"},{"text":"with a custom ","type":"text"},{"type":"codeVoice","code":"NumberFormatter"},{"text":" remains the recommended path for currency,","type":"text"},{"text":" ","type":"text"},{"text":"locale, and fraction digit rules.","type":"text"}]},{"type":"codeListing","code":["import SwiftUI","import AnimateNumberText","","struct LatencyView: View {","  @State private var value = 10.23","  @State private var textColor = Color.primary","","  var body: some View {","    AnimateNumberText(","      value: $value,","      textColor: $textColor,","      stringFormatter: \"%@ ms\"","    )","  }","}"],"syntax":"swift"},{"type":"heading","anchor":"Animation-Timing","text":"Animation Timing","level":2},{"type":"paragraph","inlineContent":[{"text":"The default animation uses ","type":"text"},{"code":".smooth(duration:)","type":"codeVoice"},{"text":", a critically damped spring that","type":"text"},{"text":" ","type":"text"},{"text":"accelerates then decelerates while preserving in-flight velocity. Pass an","type":"text"},{"type":"text","text":" "},{"identifier":"doc:\/\/com.swift-man.AnimateNumberText\/documentation\/AnimateNumberText\/AnimateNumberTextAnimation","isActive":true,"type":"reference"},{"type":"text","text":" value when the smooth rolling duration needs to"},{"type":"text","text":" "},{"type":"text","text":"be customized or when a rolling digit animation is preferred."}]},{"type":"codeListing","code":["import SwiftUI","import AnimateNumberText","","struct ScoreView: View {","  @State private var value = 120.0","  @State private var textColor = Color.primary","","  var body: some View {","    AnimateNumberText(","      value: $value,","      textColor: $textColor,","      animation: .smooth(duration: 0.5)","    )","  }","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use "},{"type":"codeVoice","code":".reel(spinningDuration:settleDuration:revolutions:)"},{"type":"text","text":" to make each digit spin through 0…9"},{"type":"text","text":" "},{"type":"text","text":"before settling. Digit columns start together, alternate direction from left to"},{"type":"text","text":" "},{"type":"text","text":"right, and stop sequentially by the settle duration. "},{"type":"codeVoice","code":"spinningDuration"},{"type":"text","text":" is the"},{"type":"text","text":" "},{"type":"text","text":"time the first digit spins before settling."}]},{"type":"codeListing","code":["AnimateNumberText(","  value: $value,","  textColor: $textColor,","  stringFormatter: \"%@ ms\",","  animation: .reel(spinningDuration: 1.5,","                   settleDuration: 0.25,","                   revolutions: 1)",")"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"For values updated at high frequency, such as drag gestures or timers, throttle"},{"type":"text","text":" "},{"type":"text","text":"or debounce the bound value at the call site when every intermediate value does"},{"text":" ","type":"text"},{"text":"not need to be rendered.","type":"text"}]}]}],"sections":[],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.swift-man.AnimateNumberText\/documentation\/AnimateNumberText"},"variants":[{"paths":["\/documentation\/animatenumbertext"],"traits":[{"interfaceLanguage":"swift"}]}],"kind":"symbol","references":{"doc://com.swift-man.AnimateNumberText/documentation/AnimateNumberText/AnimateNumberTextAnimation":{"abstract":[{"text":"Animation configuration for ","type":"text"},{"identifier":"doc:\/\/com.swift-man.AnimateNumberText\/documentation\/AnimateNumberText\/AnimateNumberText","isActive":true,"type":"reference"},{"text":" digit updates.","type":"text"}],"title":"AnimateNumberTextAnimation","type":"topic","role":"symbol","identifier":"doc:\/\/com.swift-man.AnimateNumberText\/documentation\/AnimateNumberText\/AnimateNumberTextAnimation","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"AnimateNumberTextAnimation","kind":"identifier"}],"url":"\/documentation\/animatenumbertext\/anim