{"topicSections":[{"anchor":"Views","identifiers":["doc:\/\/com.swift-man.AnimateNumberText\/documentation\/AnimateNumberText\/AnimateNumberText"],"title":"Views"},{"anchor":"Formatting","identifiers":["doc:\/\/com.swift-man.AnimateNumberText\/documentation\/AnimateNumberText\/AnimateNumberTextFormatter"],"title":"Formatting"},{"anchor":"Animation","identifiers":["doc:\/\/com.swift-man.AnimateNumberText\/documentation\/AnimateNumberText\/AnimateNumberTextAnimation"],"title":"Animation"}],"metadata":{"title":"AnimateNumberText","externalID":"AnimateNumberText","roleHeading":"Framework","symbolKind":"module","modules":[{"name":"AnimateNumberText"}],"role":"collection"},"schemaVersion":{"major":0,"minor":3,"patch":0},"kind":"symbol","primaryContentSections":[{"kind":"content","content":[{"anchor":"Overview","level":2,"type":"heading","text":"Overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use "},{"type":"codeVoice","code":"AnimateNumberText"},{"type":"text","text":" when a "},{"type":"codeVoice","code":"Double"},{"type":"text","text":" value should update visually instead of changing as a static string. The view splits the formatted value into characters, animates numeric digits vertically, and renders non-numeric characters such as currency symbols, commas, decimal points, spaces, and suffixes as text."}]},{"type":"paragraph","inlineContent":[{"text":"The package supports ","type":"text"},{"code":"NumberFormatter","type":"codeVoice"},{"text":" for localized number formatting and an optional string format for appending units such as ","type":"text"},{"code":"\"ms\"","type":"codeVoice"},{"text":" or ","type":"text"},{"code":"\"원\"","type":"codeVoice"},{"text":".","type":"text"}]},{"anchor":"Installation","level":2,"type":"heading","text":"Installation"},{"type":"paragraph","inlineContent":[{"text":"Add AnimateNumberText to your Swift package dependencies.","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["dependencies: [","  .package(url: \"https:\/\/github.com\/swift-man\/AnimateNumberText.git\", from: \"0.7.1\")","]"]},{"anchor":"Basic-Usage","level":2,"type":"heading","text":"Basic Usage"},{"type":"paragraph","inlineContent":[{"text":"Bind a numeric value and text color to ","type":"text"},{"code":"AnimateNumberText","type":"codeVoice"},{"text":".","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["import SwiftUI","import AnimateNumberText","","struct ContentView: View {","  @State private var value = 58.09","  @State private var textColor = Color.green","","  var body: some View {","    VStack {","      AnimateNumberText(","        font: .system(size: 55),","        weight: .black,","        value: $value,","        textColor: $textColor","      )","","      Button(\"Change Value\") {","        value += 1","      }","    }","  }","}"]},{"anchor":"Number-Formatting","level":2,"type":"heading","text":"Number Formatting"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Without a custom formatter, "},{"type":"codeVoice","code":"AnimateNumberText"},{"type":"text","text":" keeps fractional digits from"},{"type":"text","text":" "},{"type":"codeVoice","code":"Double"},{"type":"text","text":" values and does not add grouping separators. Pass a "},{"type":"codeVoice","code":"NumberFormatter"},{"type":"text","text":" "},{"type":"text","text":"to display currency, localized separators, or explicit fraction digit rules."}]},{"type":"codeListing","syntax":"swift","code":["import SwiftUI","import AnimateNumberText","","struct PriceView: View {","  @State private var value = 5000000.0","  @State private var textColor = Color.primary","","  private var numberFormatter: NumberFormatter {","    let formatter = NumberFormatter()","    formatter.numberStyle = .currency","    formatter.maximumFractionDigits = 0","    return formatter","  }","","  var body: some View {","    AnimateNumberText(","      value: $value,","      textColor: $textColor,","      numberFormatter: numberFormatter","    )","  }","}"]},{"text":"Read-only Values","type":"heading","anchor":"Read-only-Values","level":2},{"type":"paragraph","inlineContent":[{"text":"Use a plain ","type":"text"},{"type":"codeVoice","code":"Double"},{"text":" when the view only needs to display a value and the caller","type":"text"},{"text":" ","type":"text"},{"text":"does not need binding-based updates. The default animation is used when","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"animation"},{"text":" is omitted.","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["import SwiftUI","import AnimateNumberText","","struct SnapshotScoreView: View {","  let value = 10.23","","  var body: some View {","    AnimateNumberText(value: value)","  }","}"]},{"text":"String Formatting","type":"heading","anchor":"String-Formatting","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use "},{"type":"codeVoice","code":"stringFormatter"},{"type":"text","text":" when the formatted number needs a suffix or wrapper."},{"type":"text","text":" "},{"type":"text","text":"Prefer a "},{"type":"codeVoice","code":"%@"},{"type":"text","text":" placeholder such as "},{"type":"codeVoice","code":"\"%@ ms\""},{"type":"text","text":" when wrapping the already formatted"},{"type":"text","text":" "},{"type":"text","text":"display string. Numeric placeholders such as "},{"type":"codeVoice","code":"\"%.2f\""},{"type":"text","text":" and "},{"type":"codeVoice","code":"\"%d\""},{"type":"text","text":" are applied to"},{"type":"text","text":" "},{"type":"text","text":"the original "},{"type":"codeVoice","code":"Double"},{"type":"text","text":" value for compatibility, but "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.swift-man.AnimateNumberText\/documentation\/AnimateNumberText\/AnimateNumberTextFormatter"},{"type":"text","text":" "},{"type":"text","text":"with a custom "},{"type":"codeVoice","code":"NumberFormatter"},{"type":"text","text":" remains the recommended path for currency,"},{"type":"text","text":" "},{"type":"text","text":"locale, and fraction digit rules."}]},{"type":"codeListing","syntax":"swift","code":["import SwiftUI","import AnimateNumberText","","struct LatencyView: View {","  @State private var value = 10.23","  @State private var textColor = Color.primary","","  var body: some View {","    AnimateNumberText(","      value: $value,","      textColor: $textColor,","      stringFormatter: \"%@ ms\"","    )","  }","}"]},{"text":"Animation Timing","type":"heading","anchor":"Animation-Timing","level":2},{"type":"paragraph","inlineContent":[{"text":"The default animation uses ","type":"text"},{"code":".smooth(duration:)","type":"codeVoice"},{"text":", a critically damped spring that","type":"text"},{"text":" ","type":"text"},{"text":"accelerates then decelerates while preserving in-flight velocity. Pass an","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/com.swift-man.AnimateNumberText\/documentation\/AnimateNumberText\/AnimateNumberTextAnimation","isActive":true,"type":"reference"},{"text":" value when the smooth rolling duration needs to","type":"text"},{"text":" ","type":"text"},{"text":"be customized or when a rolling digit animation is preferred.","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["import SwiftUI","import AnimateNumberText","","struct ScoreView: View {","  @State private var value = 120.0","  @State private var textColor = Color.primary","","  var body: some View {","    AnimateNumberText(","      value: $value,","      textColor: $textColor,","      animation: .smooth(duration: 0.5)","    )","  }","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use "},{"type":"codeVoice","code":".reel(spinningDuration:settleDuration:revolutions:)"},{"type":"text","text":" to make each digit spin through 0…9"},{"type":"text","text":" "},{"type":"text","text":"before settling. Digit columns start together, alternate direction from left to"},{"type":"text","text":" "},{"type":"text","text":"right, and stop sequentially by the settle duration. "},{"type":"codeVoice","code":"spinningDuration"},{"type":"text","text":" is the"},{"type":"text","text":" "},{"type":"text","text":"time the first digit spins before settling."}]},{"syntax":"swift","code":["AnimateNumberText(","  value: $value,","  textColor: $textColor,","  stringFormatter: \"%@ ms\",","  animation: .reel(spinningDuration: 1.5,","                   settleDuration: 0.25,","                   revolutions: 1)",")"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"For values updated at high frequency, such as drag gestures or timers, throttle","type":"text"},{"text":" ","type":"text"},{"text":"or debounce the bound value at the call site when every intermediate value does","type":"text"},{"text":" ","type":"text"},{"text":"not need to be rendered.","type":"text"}]}]}],"variants":[{"paths":["\/documentation\/animatenumbertext"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"url":"doc:\/\/com.swift-man.AnimateNumberText\/documentation\/AnimateNumberText","interfaceLanguage":"swift"},"abstract":[{"text":"Animate numeric text changes with rolling digits in SwiftUI.","type":"text"}],"sections":[],"hierarchy":{"paths":[[]]},"references":{"doc://com.swift-man.AnimateNumberText/documentation/AnimateNumberText/AnimateNumberTextAnimation":{"title":"AnimateNumberTextAnimation","identifier":"doc:\/\/com.swift-man.AnimateNumberText\/documentation\/AnimateNumberText\/AnimateNumberTextAnimation","url":"\/documentation\/animatenumbertext\/animatenumbertextanimation","type":"topic","kind":"symbol","navigatorTitle":[{"text":"AnimateNumberTextAnimation","kind":"identifier"}],"abstract":[{"text":"Animation configuration for ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.swift-man.AnimateNumberText\/documentation\/AnimateNumberText\/AnimateNumberText"},{"text":" digit updates.","type":"text"}],"fragments":[{"text":"struct","ki