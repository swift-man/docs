{"variants":[{"paths":["\/documentation\/animatenumbertext"],"traits":[{"interfaceLanguage":"swift"}]}],"sections":[],"primaryContentSections":[{"kind":"content","content":[{"type":"heading","anchor":"Overview","text":"Overview","level":2},{"type":"paragraph","inlineContent":[{"text":"Use ","type":"text"},{"code":"AnimateNumberText","type":"codeVoice"},{"text":" when a ","type":"text"},{"code":"Double","type":"codeVoice"},{"text":" value should update visually instead of changing as a static string. The view splits the formatted value into characters, animates numeric digits vertically, and renders non-numeric characters such as currency symbols, commas, decimal points, spaces, and suffixes as text.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The package supports "},{"type":"codeVoice","code":"NumberFormatter"},{"type":"text","text":" for localized number formatting and an optional string format for appending units such as "},{"type":"codeVoice","code":"\"ms\""},{"type":"text","text":" or "},{"type":"codeVoice","code":"\"원\""},{"type":"text","text":"."}]},{"type":"heading","anchor":"Installation","text":"Installation","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Add AnimateNumberText to your Swift package dependencies."}]},{"type":"codeListing","syntax":"swift","code":["dependencies: [","  .package(url: \"https:\/\/github.com\/swift-man\/AnimateNumberText.git\", from: \"0.7.0\")","]"]},{"type":"heading","anchor":"Basic-Usage","text":"Basic Usage","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Bind a numeric value and text color to "},{"type":"codeVoice","code":"AnimateNumberText"},{"type":"text","text":"."}]},{"type":"codeListing","syntax":"swift","code":["import SwiftUI","import AnimateNumberText","","struct ContentView: View {","  @State private var value = 58.09","  @State private var textColor = Color.green","","  var body: some View {","    VStack {","      AnimateNumberText(","