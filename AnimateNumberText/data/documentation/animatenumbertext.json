er":"doc:\/\/com.swift-man.AnimateNumberText\/documentation\/AnimateNumberText\/AnimateNumberTextAnimation","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"AnimateNumberTextAnimation"}],"role":"symbol","kind":"symbol","navigatorTitle":[{"kind":"identifier","text":"AnimateNumberTextAnimation"}],"title":"AnimateNumberTextAnimation"},"doc://com.swift-man.AnimateNumberText/documentation/AnimateNumberText":{"abstract":[{"text":"Animate numeric text changes with rolling digits in SwiftUI.","type":"text"}],"role":"collection","title":"AnimateNumberText","type":"topic","identifier":"doc:\/\/com.swift-man.AnimateNumberText\/documentation\/AnimateNumberText","kind":"symbol","url":"\/documentation\/animatenumbertext"}}}