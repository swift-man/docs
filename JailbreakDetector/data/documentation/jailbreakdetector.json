{"metadata":{"roleHeading":"Framework","title":"JailbreakDetector","symbolKind":"module","role":"collection","modules":[{"name":"JailbreakDetector"}],"externalID":"JailbreakDetector"},"hierarchy":{"paths":[[]]},"sections":[],"topicSections":[{"identifiers":["doc:\/\/com.swift-man.JailbreakDetector\/documentation\/JailbreakDetector\/JailbreakDetector","doc:\/\/com.swift-man.JailbreakDetector\/documentation\/JailbreakDetector\/JailbreakDetecting","doc:\/\/com.swift-man.JailbreakDetector\/documentation\/JailbreakDetector\/JailbreakCheckOptions","doc:\/\/com.swift-man.JailbreakDetector\/documentation\/JailbreakDetector\/JailbreakDetectionError"],"title":"Detection","anchor":"Detection"}],"schemaVersion":{"major":0,"patch":0,"minor":3},"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/jailbreakdetector"]}],"abstract":[{"type":"text","text":"A lightweight Swift package for detecting common jailbreak indicators on iOS."}],"primaryContentSections":[{"content":[{"level":2,"anchor":"Overview","type":"heading","text":"Overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use JailbreakDetector to run a small set of jailbreak checks before enabling security-sensitive app flows."}]},{"type":"paragraph","inlineContent":[{"text":"The detector skips checks when running in the simulator. On device, the default configuration checks suspicious application paths, suspicious system paths, sandbox write behavior, loaded dynamic libraries, and suspicious runtime environment variables. Environment variable checks are skipped for debug builds to avoid flagging legitimate development tooling. Release and TestFlight builds keep these checks enabled.","type":"text"}]},{"level":2,"anchor":"Installation","type":"heading","text":"Installation"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Add JailbreakDetector as a Swift Package dependency:"}]},{"syntax":"swift","code":[".package(url: \"https:\/\/github.com\/swift-man\/JailbreakDetector\", .upToNextMinor(from: \"0.5.2\"))"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"JailbreakDetector supports iOS 15.0 and later.","type":"text"}]},{"level":2,"anchor":"Usage","type":"heading","text":"Usage"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Create a detector and call "},{"type":"reference","identifier":"doc:\/\/com.swift-man.JailbreakDetector\/documentation\/JailbreakDetector\/JailbreakDetector\/detect(options:)","isActive":true},{"type":"text","text":"."}]},{"syntax":"swift","code":["import JailbreakDetector","","let detector = JailbreakDetector()","","do {","  try detector.detect()","} catch let error as JailbreakDetectionError {","  print(\"Jailbreak detected: \\(error.code), \\(error.message)\")","} catch {","  print(\"Jailbreak detection failed: \\(error)\")","}"],"type":"codeListing"},{"level":2,"anchor":"Custom-Checks","type":"heading","text":"Custom Checks"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Pass "},{"type":"reference","identifier":"doc:\/\/com.swift-man.JailbreakDetector\/documentation\/JailbreakDetector\/JailbreakCheckOptions","isActive":true},{"type":"text","text":" to choose which checks should run."}]},{"syntax":"swift","code":["try detector.detect(options: [.filePathChecks, .sandboxWrite, .dyldScan, .environmentVariableChecks])"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.swift-man.JailbreakDetector\/documentation\/JailbreakDetector\/JailbreakCheckOptions\/all"},{"type":"text","text":" only when the app should also run the more aggressive system write probe."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"reference","identifier":"doc:\/\/com.swift-man.JailbreakDetector\/documentation\/JailbreakDetector\/JailbreakCheckOptions\/sandboxWrite","isActive":true},{"type":"text","text":" and "},{"type":"reference","identifier":"doc:\/\/com.swift-man.JailbreakDetector\/documentation\/JailbreakDetector\/JailbreakCheckOptions\/systemWrite","isActive":true},{"type":"text","text":" checks intentionally attempt writes outside the app sandbox. Failed writes are expected on non-jailbroken devices, but they can create diagnostic or crash-reporting noise in some production telemetry. If that is a problem for your app, pass a custom option set that omits those checks."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"In debug builds, "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.swift-man.JailbreakDetector\/documentation\/JailbreakDetector\/JailbreakCheckOptions\/environmentVariableChecks"},{"type":"text","text":" is removed even when it is included in a custom option set. Release and TestFlight builds honor the option as passed."}]},{"type":"paragraph","inlineContent":[{"text":"JailbreakDetector intentionally avoids URL scheme checks such as ","type":"text"},{"code":"cydia:\/\/","type":"codeVoice"},{"text":", ","type":"text"},{"code":"sileo:\/\/","type":"codeVoice"},{"text":", ","type":"text"},{"code":"zebra:\/\/","type":"codeVoice"},{"text":", and ","type":"text"},{"code":"filza:\/\/","type":"codeVoice"},{"text":" in its default flow because those schemes can be registered without proving that the device is jailbroken.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Rootless "},{"type":"codeVoice","code":"\/var\/jb"},{"type":"text","text":" symbolic link findings are reported as "},{"type":"reference","identifier":"doc:\/\/com.swift-man.JailbreakDetector\/documentation\/JailbreakDetector\/JailbreakDetectionError\/suspiciousSymbolicLink(path:)","isActive":true},{"type":"text","text":" with error code "},{"type":"codeVoice","code":"08"},{"type":"text","text":", so telemetry can distinguish symlink-based signals from regular suspicious system paths."}]},{"level":2,"anchor":"Version","type":"heading","text":"Version"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The current release is 0.5.2."}]}],"kind":"content"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.swift-man.JailbreakDetector\/documentation\/JailbreakDetector"},"references":{"doc://com.swift-man.JailbreakDetector/documentation/JailbreakDetector/JailbreakCheckOptions/environmentVariableChecks":{"identifier":"doc:\/\/com.swift-man.JailbreakDetector\/documentation\/JailbreakDetector\/JailbreakCheckOptions\/environmentVariableChecks","kind":"symbol","type":"topic","title":"environmentVariableChecks","fragments":[{"kind":"keyword","text":"static"},{"kind":"text","text":" "},{"kind":"keyword","text":"let"},{"kind":"text","text":" "},{"kind":"identifier","text":"environmentVariableChecks"},{"kind":"text","text":": "},{"preciseIdentifier":"s:17JailbreakDetector0A12CheckOptionsV","kind":"typeIdentifier","text":"JailbreakCheckOptions"}],"abstract":[],"url":"\/documentation\/jailbreakdetector\/jailbreakcheckoptions\/environmentvariablechecks","role":"symbol"},"doc://com.swift-man.JailbreakDetector/documentation/JailbreakDetector/JailbreakDetectionError":{"title":"JailbreakDetectionError","role":"symbol","url":"\/documentation\/jailbreakdetector\/jailbreakdetectionerror","identifier":"doc:\/\/com.swift-man.JailbreakDetector\/documentation\/JailbreakDetector\/JailbreakDetectionError","abstract":[],"navigatorTitle":[{"kind":"identifier","text":"JailbreakDetectionError"}],"fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"JailbreakDetectionError"}],"type":"topic","kind":"symbol"},"doc://com.swift-man.JailbreakDetector/documentation/JailbreakDetector/JailbreakDetector":{"navigatorTitle":[{"text":"JailbreakDetector","kind":"identifier"}],"kind":"symbol","identifier":"doc:\/\/com.swift-man.JailbreakDetector\/documentation\/JailbreakDetector\/JailbreakDetector","url":"\/documentation\/jailbreakdetector\/jailbreakdetector","fragments":[{"text":"struct","kind":"keyword"},{"text":" 