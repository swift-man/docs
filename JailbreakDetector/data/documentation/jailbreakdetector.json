{"kind":"symbol","primaryContentSections":[{"kind":"content","content":[{"text":"Overview","anchor":"Overview","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"Use JailbreakDetector to run a small set of jailbreak checks before enabling security-sensitive app flows."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The detector skips checks when running in the simulator. On device, the default configuration checks suspicious application paths, suspicious system paths, sandbox write behavior, and loaded dynamic libraries. Suspicious runtime environment variable checks are opt-in to keep normal app launches at a lower false-positive risk."}],"type":"paragraph"},{"text":"Installation","anchor":"Installation","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"Add JailbreakDetector as a Swift Package dependency:"}],"type":"paragraph"},{"code":[".package(url: \"https:\/\/github.com\/swift-man\/JailbreakDetector\", .upToNextMinor(from: \"0.5.5\"))"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"type":"text","text":"JailbreakDetector supports iOS 15.0 and later."}],"type":"paragraph"},{"text":"Usage","anchor":"Usage","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"Create a "},{"type":"reference","identifier":"doc:\/\/com.swift-man.JailbreakDetector\/documentation\/JailbreakDetector\/JailbreakDetector","isActive":true},{"type":"text","text":" and call "},{"type":"codeVoice","code":"detect(options:)"},{"type":"text","text":"."}],"type":"paragraph"},{"code":["import JailbreakDetector","","let detector = JailbreakDetector()","","do {","  try detector.detect()","} catch let error as JailbreakDetectionError {","  print(\"Jailbreak detected: \\(error.code), \\(error.message)\")","} catch {","  print(\"Jailbreak detection failed: \\(error)\")","}"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"type":"text","text":"Use the async overload in app-launch and main-actor flows so file-system checks do not block the caller’s executor:"}],"type":"paragraph"},{"code":["try await detector.detect()"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"type":"text","text":"The async overload preserves the same options and errors as synchronous detection. The built-in detector cooperatively checks cancellation between detection stages and individual path or dynamic-library candidates."}],"type":"paragraph"},{"text":"Custom Checks","anchor":"Custom-Checks","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"Pass "},{"type":"reference","identifier":"doc:\/\/com.swift-man.JailbreakDetector\/documentation\/JailbreakDetector\/JailbreakCheckOptions","isActive":true},{"type":"text","text":" to choose which checks should run."}],"type":"paragraph"},{"code":["try detector.detect(options: [.filePathChecks, .sandboxWrite, .dyldScan, .environmentVariableChecks])"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"type":"text","text":"Use "},{"type":"reference","identifier":"doc:\/\/com.swift-man.JailbreakDetector\/documentation\/JailbreakDetector\/JailbreakCheckOptions\/all","isActive":true},{"type":"text","text":" only when the app should also run the more aggressive system write probe."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The "},{"type":"reference","identifier":"doc:\/\/com.swift-man.JailbreakDetector\/documentation\/JailbreakDetector\/JailbreakCheckOptions\/sandboxWrite","isActive":true},{"type":"text","text":" and "},{"type":"reference","identifier":"doc:\/\/com.swift-man.JailbreakDetector\/documentation\/JailbreakDetector\/JailbreakCheckOptions\/systemWrite","isActive":true},{"type":"text","text":" checks intentionally attempt writes outside the app sandbox. Failed writes are expected on non-jailbroken devices, but they can create diagnostic or crash-reporting noise in some production telemetry. If that is a problem for your app, pass a custom option set that omits those checks."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Use "},{"type":"reference","identifier":"doc:\/\/com.swift-man.JailbreakDetector\/documentation\/JailbreakDetector\/JailbreakCheckOptions\/strict","isActive":true},{"type":"text","text":" when the app should also treat suspicious "},{"type":"codeVoice","code":"DYLD_*"},{"type":"text","text":" environment variables as blocking signals. In debug builds, "},{"type":"reference","identifier":"doc:\/\/com.swift-man.JailbreakDetector\/documentation\/JailbreakDetector\/JailbreakCheckOptions\/environmentVariableChecks","isActive":true},{"type":"text","text":" is removed even when it is included in a custom option set. Release and TestFlight builds honor the option as passed."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"JailbreakDetector intentionally avoids URL scheme checks such as "},{"type":"codeVoice","code":"cydia:\/\/"},{"type":"text","text":", "},{"type":"codeVoice","code":"sileo:\/\/"},{"type":"text","text":", "},{"type":"codeVoice","code":"zebra:\/\/"},{"type":"text","text":", and "},{"type":"codeVoice","code":"filza:\/\/"},{"type":"text","text":" in its default flow because those schemes can be registered without proving that the device is jailbroken."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Rootless "},{"type":"codeVoice","code":"\/var\/jb"},{"type":"text","text":" symbolic link findings are reported as "},{"type":"reference","identifier":"doc:\/\/com.swift-man.JailbreakDetector\/documentation\/JailbreakDetector\/JailbreakDetectionError\/suspiciousSymbolicLink(path:)","isActive":true},{"type":"text","text":" with error code "},{"type":"codeVoice","code":"08"},{"type":"text","text":", so telemetry can distinguish symlink-based signals from regular suspicious system paths."}],"type":"paragraph"},{"text":"Version","anchor":"Version","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"The current release is 0.5.5."}],"type":"paragraph"}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.swift-man.JailbreakDetector\/documentation\/JailbreakDetector"},"sections":[],"hierarchy":{"paths":[[]]},"abstract":[{"text":"A lightweight Swift package for detecting common jailbreak indicators on iOS.","type":"text"}],"variants":[{"paths":["\/documentation\/jailbreakdetector"],"traits":[{"interfaceLanguage":"swift"}]}],"schemaVersion":{"patch":0,"major":0,"minor":3},"topicSections":[{"identifiers":["doc:\/\/com.swift-man.JailbreakDetector\/documentation\/JailbreakDetector\/JailbreakDetector","doc:\/\/com.swift-man.JailbreakDetector\/documentation\/JailbreakDetector\/JailbreakDetecting","doc:\/\/com.swift-man.JailbreakDetector\/documentation\/JailbreakDetector\/JailbreakCheckOptions","doc:\/\/com.swift-man.JailbreakDetector\/documentation\/JailbreakDetector\/JailbreakDetectionError"],"anchor":"Detection","title":"Detection"}],"metadata":{"title":"JailbreakDetector","symbolKind":"module","role":"collection","roleHeading":"Framework","externalID":"JailbreakDetector","modules":[{"name":"JailbreakDetector"}]},"references":{"doc://com.swift-man.JailbreakDetector/documentation/JailbreakDetector/JailbreakCheckOptions/environmentVariableChecks":{"kind":"symbol","identifier":"doc:\/\/com.swift-man.JailbreakDetector\/documentation\/JailbreakDetector\/JailbreakCheckOptions\/environmentVariableChecks","type":"topic","fragments":[{"kind":"keyword","text":"static"},{"kind":"text","text":" "},{"kind":"keyword","text":"let"},{"kind":"text","text":" "},{"kind":"identifier","text":"environmentVariableChecks"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:17JailbreakDetector0A12CheckOptionsV","text":"JailbreakCheckOptions"}],"url":"\/documentation\/jailbreakdetector\/jailbreakcheckoptions\/environmentvariablechecks","abstract":[],"role":"symbol","title":"environmentVariableChecks"},"doc://com.swift-man.JailbreakDetector/documentation/JailbreakDetector/JailbreakCheckOptions/all":{"kind":"symbol","identifier":"doc:\/\/com.swift-man.JailbreakDetector\/documentation\/JailbreakDetector\/JailbreakCheckOptions\/all","type":"topic","fragments":[{"kind":"keyword","text":"static"},{"kind":"text","text":" "},{"kind":"keyword","text":"let"},{"kind":"text","text":" "},{"kind":"identifier","text":"all"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:17JailbreakDetector0A12CheckOptionsV","text":"JailbreakCheckOptions"}],"url":"\/documentation\/jailbreakdetector\/jailbreakcheckoptions\/all","abstract":[],"role":"symbol","title":"all"},"doc://com.swift-man.JailbreakDetector/documentation/JailbreakDetector/JailbreakCheckOptions/sandboxWrite":{"kind":"symbol","identifier":"doc:\/\/com.swift-man.JailbreakDetector\/documentation\/JailbreakDetector\/JailbreakCheckOptions\/sandboxWrite","type":"topic","fragments":[{"kind":"keyword","text":"static"},{"kind":"text","text":" "},{"text":"let","kind":"keyword"},{"text":" ","kind":"text"},{"text":"sandboxWrite","kind":"identifier"},{"text":": ","kind":"text"},{"text":"JailbreakCheckOptions","kind":"typeIdentifier","preciseIdentifier":"s:17JailbreakDetector0A12CheckOptionsV"}],"url":"\/documentation\/jailbreakdetector\/jailbreakcheckoptions\/sandboxwrite","abstract":[],"role":"symbol","title":"sandboxWrite"},"doc://com.swift-man.JailbreakDetector/documentation/JailbreakDetector/JailbreakDetectionError":{"type":"topic","url":"\/documentation\/jailbreakdetector\/jailbreakdetectionerror","title":"JailbreakDetectionError","role":"symbol","abstract":[],"identifier":"doc:\/\/com.swift-man.JailbreakDetector\/documentation\/JailbreakDetector\/JailbreakDetectionError","fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"JailbreakDetectionError"}],"navigatorTitle":[{"kind":"identifier","text":"JailbreakDetectionError"}],"kind":"symbol"},"doc://com.swift-man.JailbreakDetector/documentation/JailbreakDetector/JailbreakCheckOptions/systemWrite":{"type":"topic","url":"\/documentation\/jailbreakdetector\/j